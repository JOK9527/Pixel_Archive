---
import SectionHeader from "../components/ui/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="关于 Pixel Archive 的简短说明。">
  <article class="about">
    <SectionHeader
      eyebrow="Archive note"
      title="About"
      description="Pixel Archive 是一个个人档案馆，用来存放项目、笔记、阶段存档和一些实验性内容。"
    />

    <div class="about__note">
      <p>
        这里保留正在完成的工具、学习记录和小型视觉实验。内容会逐步写入，
        页面本身保持安静、清晰并适合长期维护。
      </p>
      <dl>
        <div>
          <dt>Mode</dt>
          <dd>quiet archive</dd>
        </div>
        <div>
          <dt>Built with</dt>
          <dd>Astro / MDX</dd>
        </div>
      </dl>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: 48rem;
  }

  .about__note {
    max-width: 40rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .about__note > p {
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }

  .about__note dl {
    display: grid;
    margin: 0;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .about__note dl div {
    padding: 0.85rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .about__note dt {
    color: var(--color-green);
    font-size: 0.65rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .about__note dd {
    margin: 0.3rem 0 0;
    color: var(--color-text);
  }

  @media (max-width: 32rem) {
    .about__note dl {
      grid-template-columns: 1fr;
    }
  }
</style>
