---
import SectionHeader from "../components/ui/SectionHeader.astro";
import SideRail from "../components/ui/SideRail.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="关于 Pixel Archive 的简短说明。">
  <article class="about">
    <SectionHeader
      eyebrow="Archive note"
      title="About"
      description="Pixel Archive 是一个个人档案馆，用来存放项目、笔记、阶段存档和一些实验性内容。"
    />

    <div class="about__layout">
      <SideRail
        title="Archive Profile"
        code="V20"
        grid
        items={[
          { label: "Coordinate", value: "PA / ABOUT / 06" },
          { label: "Version", value: "Phase 20" },
          { label: "Built with", value: "Astro / MDX / CSS" },
          { label: "Mode", value: "quiet archive" },
        ]}
      />
      <div class="about__content">
        <div class="about__note">
          <p>
            这里保留正在完成的 Web 工具、阅读与知识整理实践、开发笔记、
            阶段保存点和小型界面实验。内容以可核验、可公开和可长期维护为前提。
          </p>
          <dl>
            <div>
              <dt>Mode</dt>
              <dd>quiet archive</dd>
            </div>
            <div>
              <dt>Built with</dt>
              <dd>Astro / MDX</dd>
            </div>
            <div>
              <dt>Focus</dt>
              <dd>web tools / reading systems / interface studies</dd>
            </div>
            <div>
              <dt>Privacy</dt>
              <dd>public facts only / screenshots reviewed before release</dd>
            </div>
          </dl>
        </div>

        <nav class="about__map" aria-label="Archive content map">
          <a href="/projects/">
            <span>01 / PROJECTS</span>
            <strong>长期项目与当前状态</strong>
          </a>
          <a href="/notes/">
            <span>02 / NOTES</span>
            <strong>文章、日志与技术记录</strong>
          </a>
          <a href="/archive/">
            <span>03 / ARCHIVE</span>
            <strong>可按时间回看的阶段保存点</strong>
          </a>
          <a href="/lab/">
            <span>04 / LAB</span>
            <strong>尚在验证的界面与像素实验</strong>
          </a>
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: var(--content-width);
  }

  .about__layout {
    display: grid;
    grid-template-columns: var(--layout-sidebar) minmax(0, 1fr);
    align-items: start;
    gap: var(--layout-gap);
  }

  .about__content {
    min-width: 0;
  }

  .about__note {
    max-width: var(--measure-reading);
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .about__note > p {
    max-width: var(--measure-narrow);
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }

  .about__note dl {
    display: grid;
    margin: 0;
    border-block: 1px solid var(--color-border);
    gap: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .about__note dl div {
    display: grid;
    padding: 0.8rem 0;
    border-bottom: 1px dashed var(--color-border);
    grid-template-columns: minmax(6rem, 0.32fr) 1fr;
    align-items: baseline;
    gap: 1rem;
  }

  .about__note dl div:last-child {
    border-bottom: 0;
  }

  .about__note dt {
    color: var(--section-accent);
    font-size: 0.65rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .about__note dd {
    margin: 0;
    color: var(--color-text);
  }

  .about__map {
    display: grid;
    margin-top: 3rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .about__map a {
    display: grid;
    min-width: 0;
    min-height: 7rem;
    padding: 1rem;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-raised);
    color: var(--color-text);
    align-content: space-between;
    gap: 1.5rem;
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .about__map a:hover,
  .about__map a:focus-visible {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-pixel-green);
    transform: translate(-2px, -2px);
  }

  .about__map span {
    color: var(--section-accent);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.07em;
  }

  .about__map strong {
    font-size: 0.88rem;
    line-height: 1.5;
  }

  @media (max-width: 32rem) {
    .about__note dl div {
      grid-template-columns: 5.5rem 1fr;
    }

    .about__map {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 52rem) {
    .about__layout {
      grid-template-columns: 1fr;
    }
  }
</style>
