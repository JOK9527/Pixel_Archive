---
import ArchiveTimeline from "../components/archive/ArchiveTimeline.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import SectionIndex from "../components/ui/SectionIndex.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getAllArchiveEntries,
  groupArchiveEntries,
} from "../lib/content/archive";
import { getArchiveTaxonomy } from "../lib/content/taxonomy";

const entries = await getAllArchiveEntries();
const groups = groupArchiveEntries(entries);
const taxonomy = getArchiveTaxonomy(entries);
---

<BaseLayout title="Archive" description="重要节点和阶段存档。">
  <SectionHeader
    eyebrow="Save point index"
    title="Archive"
    description="重要节点和阶段存档。"
  />
  {
    groups.length > 0 ? (
      <div class="archive-layout">
        <SectionIndex
          title="Archive Index"
          groups={taxonomy}
          filterRoot="archive"
          total={entries.length}
        />
        <ArchiveTimeline groups={groups} filterRoot="archive" />
      </div>
    ) : (
      <EmptyState
        title="No save points yet."
        description="下一条阶段记录还在路上。"
        variant="terminal"
      />
    )
  }
</BaseLayout>

<style>
  .archive-layout {
    display: grid;
    grid-template-columns: var(--layout-sidebar) minmax(0, 1fr);
    align-items: start;
    gap: var(--layout-gap);
  }

  @media (max-width: 54rem) {
    .archive-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
