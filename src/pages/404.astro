---
import EmptyState from "../components/ui/EmptyState.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="save file not found"
  description="The file you are looking for is not in this archive."
>
  <div class="lost-archive">
    <p class="lost-archive__code">ERROR / 404</p>
    <h1>lost archive</h1>
    <EmptyState
      title="save file not found"
      description="The file you are looking for is not in this archive."
      actionLabel="Return Home"
      actionHref="/"
      variant="terminal"
    />
  </div>
</BaseLayout>

<style>
  .lost-archive {
    max-width: 52rem;
    margin-inline: auto;
  }

  .lost-archive__code {
    margin-bottom: 0.6rem;
    color: var(--color-danger);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .lost-archive > h1 {
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: clamp(2.8rem, 9vw, 5.8rem);
    letter-spacing: -0.07em;
    line-height: 0.95;
    text-transform: lowercase;
  }
</style>
