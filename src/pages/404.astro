---
import EmptyState from "../components/ui/EmptyState.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="save file not found"
  description="The file you are looking for is not in this archive."
>
  <div class="lost-archive">
    <p class="lost-archive__code">ERROR / 404</p>
    <h1>lost archive</h1>
    <div class="lost-archive__signal" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <EmptyState
      title="save file not found"
      description="This path has no matching save file. Return to the archive terminal and load another slot."
      actionLabel="Return Home"
      actionHref="/"
      variant="terminal"
    />
  </div>
</BaseLayout>

<style>
  .lost-archive {
    max-width: 52rem;
    margin-inline: auto;
  }

  .lost-archive__code {
    margin-bottom: 0.6rem;
    color: var(--color-danger);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .lost-archive > h1 {
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: clamp(2.8rem, 9vw, 5.8rem);
    letter-spacing: -0.07em;
    line-height: 0.95;
    text-transform: lowercase;
  }

  .lost-archive__signal {
    display: flex;
    height: 1.8rem;
    margin-bottom: 1.5rem;
    align-items: end;
    gap: 0.35rem;
  }

  .lost-archive__signal span {
    width: 0.55rem;
    background: var(--color-border);
  }

  .lost-archive__signal span:nth-child(1) {
    height: 35%;
  }

  .lost-archive__signal span:nth-child(2) {
    height: 75%;
    background: var(--color-danger);
  }

  .lost-archive__signal span:nth-child(3) {
    height: 45%;
  }

  .lost-archive__signal span:nth-child(4) {
    height: 90%;
    background: var(--color-purple);
  }

  .lost-archive__signal span:nth-child(5) {
    height: 25%;
  }
</style>
