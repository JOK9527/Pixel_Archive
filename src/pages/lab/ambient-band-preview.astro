---
import AmbientBandPreviewCard from "../../components/visual/AmbientBandPreviewCard.astro";
import {
  ambientBandPreviews,
  ambientBandSections,
} from "../../data/ambient-band-variants";
import BaseLayout from "../../layouts/BaseLayout.astro";

const candidateCount = ambientBandPreviews.filter(
  (sample) => sample.status === "candidate",
).length;
---

<BaseLayout
  title="Ambient Pixel Band Preview"
  description="Phase 24B visual comparison library for deterministic ambient pixel bands."
  robots="noindex, nofollow"
>
  <section class="ambient-library">
    <header class="ambient-library__intro">
      <p class="ambient-library__eyebrow ui-label">
        LAB / AMBIENT BAND PREVIEW
      </p>
      <h1>Ambient Pixel Band</h1>
      <p>
        4 个栏目与 4 种几何走向的静态样例库。当前只用于比较可见度、折面、
        像素网格和文字安全区，不接入任何真实详情页。
      </p>
      <dl>
        <div>
          <dt>samples</dt>
          <dd>16</dd>
        </div>
        <div>
          <dt>candidates</dt>
          <dd>{candidateCount}</dd>
        </div>
        <div>
          <dt>approved</dt>
          <dd>0 / USER REVIEW</dd>
        </div>
        <div>
          <dt>debug</dt>
          <dd id="ambient-debug-status">?ambient=debug</dd>
        </div>
      </dl>
    </header>

    <aside class="ambient-library__criteria" aria-label="Review criteria">
      <strong class="ui-label">REVIEW FILTER</strong>
      <span>visible but restrained</span>
      <span>geometric, not a shadow</span>
      <span>pixel texture, not random dots</span>
      <span>clear section identity</span>
    </aside>

    {
      ambientBandSections.map((group) => {
        const samples = ambientBandPreviews.filter(
          (sample) => sample.section === group.section,
        );

        return (
          <section
            class={`ambient-library__group ambient-library__group--${group.section}`}
            aria-labelledby={`ambient-${group.section}`}
          >
            <header>
              <div>
                <p class="ui-label">{group.section} palette</p>
                <h2 id={`ambient-${group.section}`}>{group.label}</h2>
              </div>
              <p>{group.description}</p>
            </header>
            <div class="ambient-library__grid">
              {samples.map((sample) => (
                <AmbientBandPreviewCard sample={sample} />
              ))}
            </div>
          </section>
        );
      })
    }
  </section>
  <script is:inline>
    (() => {
      const enabled =
        new URLSearchParams(window.location.search).get("ambient") === "debug";
      if (!enabled) return;

      document.documentElement.dataset.ambientDebug = "true";
      const status = document.getElementById("ambient-debug-status");
      if (status) status.textContent = "ON";
    })();
  </script>
</BaseLayout>

<style>
  .ambient-library {
    max-width: 76rem;
    margin-inline: auto;
  }

  .ambient-library__intro {
    max-width: 56rem;
    margin-bottom: var(--space-6);
  }

  .ambient-library__eyebrow {
    margin-bottom: var(--space-3);
    color: var(--section-lab-main);
    font-size: 0.68rem;
    font-weight: 700;
  }

  .ambient-library__intro h1 {
    max-width: 10ch;
    margin-bottom: var(--space-4);
    font-size: clamp(3.3rem, 9vw, 7.4rem);
    letter-spacing: -0.075em;
    line-height: 0.86;
  }

  .ambient-library__intro > p:not(.ambient-library__eyebrow) {
    max-width: 43rem;
    color: var(--color-text-muted);
    font-size: clamp(0.98rem, 2vw, 1.08rem);
  }

  .ambient-library__intro dl {
    display: grid;
    max-width: 46rem;
    margin: var(--space-6) 0 0;
    border-block: 1px solid var(--color-border);
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .ambient-library__intro dl div {
    min-width: 0;
    padding: 0.7rem 0.8rem;
    border-right: 1px solid var(--color-border);
  }

  .ambient-library__intro dl div:last-child {
    border-right: 0;
  }

  .ambient-library__intro dt,
  .ambient-library__intro dd {
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .ambient-library__intro dt {
    color: var(--color-text-faint);
  }

  .ambient-library__intro dd {
    margin: 0.2rem 0 0;
    overflow-wrap: anywhere;
    color: var(--color-heading);
    font-weight: 700;
  }

  .ambient-library__criteria {
    display: flex;
    margin-bottom: var(--space-8);
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    flex-wrap: wrap;
    gap: 0.6rem 1.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
  }

  .ambient-library__criteria strong {
    color: var(--section-lab-main);
  }

  .ambient-library__group {
    --group-accent: var(--section-lab-main);
    margin-top: var(--space-9);
  }

  .ambient-library__group--projects {
    --group-accent: var(--section-projects-main);
  }

  .ambient-library__group--notes {
    --group-accent: var(--section-notes-main);
  }

  .ambient-library__group--archive {
    --group-accent: var(--section-archive-main);
  }

  .ambient-library__group > header {
    display: grid;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    grid-template-columns: minmax(12rem, 0.8fr) minmax(18rem, 1.2fr);
    align-items: end;
    gap: var(--space-6);
  }

  .ambient-library__group > header .ui-label {
    margin-bottom: 0.3rem;
    color: var(--group-accent);
    font-size: 0.6rem;
    font-weight: 700;
  }

  .ambient-library__group h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.4rem);
    letter-spacing: -0.055em;
    line-height: 0.95;
  }

  .ambient-library__group > header > p {
    max-width: 34rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }

  .ambient-library__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }

  @media (max-width: 52rem) {
    .ambient-library__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 42rem) {
    .ambient-library__intro h1 {
      max-width: 9ch;
      font-size: clamp(3rem, 17vw, 4.8rem);
    }

    .ambient-library__intro dl {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ambient-library__intro dl div:nth-child(2) {
      border-right: 0;
    }

    .ambient-library__intro dl div:nth-child(-n + 2) {
      border-bottom: 1px solid var(--color-border);
    }

    .ambient-library__group {
      margin-top: var(--space-8);
    }

    .ambient-library__group > header {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
