---
import LabGrid from "../components/lab/LabGrid.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import SectionIndex from "../components/ui/SectionIndex.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllLabItems } from "../lib/content/lab";
import { getLabTaxonomy } from "../lib/content/taxonomy";

const items = await getAllLabItems();
const taxonomy = getLabTaxonomy(items);
---

<BaseLayout title="Lab" description="视觉、像素和小工具实验。">
  <SectionHeader
    eyebrow="Experiment slot"
    title="Lab"
    description="一些视觉、像素和小工具实验。"
  />
  {
    items.length > 0 ? (
      <div class="lab-layout">
        <SectionIndex
          title="Lab Index"
          groups={taxonomy}
          filterRoot="lab"
          total={items.length}
        />
        <LabGrid items={items} filterRoot="lab" />
      </div>
    ) : (
      <EmptyState
        title="This lab slot is still empty."
        description="下一次实验还没有载入。"
        variant="pixel"
      />
    )
  }
</BaseLayout>

<style>
  .lab-layout {
    display: grid;
    grid-template-columns: var(--layout-sidebar) minmax(0, 1fr);
    align-items: start;
    gap: var(--layout-gap);
  }

  @media (max-width: 54rem) {
    .lab-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
