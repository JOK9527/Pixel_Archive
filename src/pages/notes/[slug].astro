---
import { getEntry, render } from "astro:content";
import NoteLayout from "../../layouts/NoteLayout.astro";
import { getPublishedNotes, type NoteItem } from "../../lib/content/notes";

export async function getStaticPaths() {
  const notes = await getPublishedNotes();

  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

type Props = {
  note: NoteItem;
};

const { note } = Astro.props;
const entry = await getEntry("notes", note.slug);

if (!entry || entry.data.draft) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);
const notes = await getPublishedNotes();
const noteIndex = notes.findIndex((item) => item.slug === note.slug);
const newerNote = noteIndex > 0 ? notes[noteIndex - 1] : undefined;
const olderNote =
  noteIndex >= 0 && noteIndex < notes.length - 1
    ? notes[noteIndex + 1]
    : undefined;
---

<NoteLayout
  note={note}
  headings={headings}
  newerNote={newerNote}
  olderNote={olderNote}
>
  <Content />
</NoteLayout>
