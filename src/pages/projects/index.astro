---
import EmptyState from "../../components/ui/EmptyState.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import FeaturedProjects from "../../components/project/FeaturedProjects.astro";
import ProjectGrid from "../../components/project/ProjectGrid.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllProjects,
  getFeaturedProjects,
} from "../../lib/content/projects";

const projects = await getAllProjects();
const featuredProjects = await getFeaturedProjects();
const regularProjects = projects.filter((project) => !project.featured);
---

<BaseLayout
  title="Projects"
  description="正在完成、已经完成和暂时搁置的项目。"
>
  <SectionHeader
    eyebrow="Archive drawer / 01"
    title="Projects"
    description="一些正在完成、已经完成和暂时搁置的项目。"
  />
  {
    projects.length > 0 ? (
      <>
        <FeaturedProjects projects={featuredProjects} />
        <section class="projects-index" aria-labelledby="all-projects-title">
          <header>
            <h2 id="all-projects-title">Project Archive</h2>
            <span>
              {regularProjects.length.toString().padStart(2, "0")} secondary files
            </span>
          </header>
          <ProjectGrid projects={regularProjects} />
        </section>
      </>
    ) : (
      <EmptyState
        title="New project slots are waiting."
        description="项目档案暂未写入，稍后再来读取。"
        variant="pixel"
      />
    )
  }
</BaseLayout>

<style>
  .projects-index > header {
    display: grid;
    margin-bottom: 1.4rem;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 0.25rem 1rem;
  }

  .projects-index h2 {
    margin-bottom: 0;
    font-size: clamp(1.8rem, 5vw, 2.7rem);
    letter-spacing: -0.05em;
  }

  .projects-index > header span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    grid-column: 2;
  }

  @media (max-width: 32rem) {
    .projects-index > header {
      grid-template-columns: 1fr;
    }

    .projects-index > header span {
      margin-top: 0.35rem;
      grid-column: 1;
      grid-row: auto;
    }
  }
</style>
