---
import EmptyState from "../../components/ui/EmptyState.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import SectionIndex from "../../components/ui/SectionIndex.astro";
import FeaturedProjects from "../../components/project/FeaturedProjects.astro";
import ProjectGrid from "../../components/project/ProjectGrid.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllProjects,
  getFeaturedProjects,
} from "../../lib/content/projects";
import { getProjectTaxonomy } from "../../lib/content/taxonomy";

const projects = await getAllProjects();
const featuredProjects = await getFeaturedProjects();
const regularProjects = projects.filter((project) => !project.featured);
const taxonomy = getProjectTaxonomy(projects);
---

<BaseLayout
  title="Projects"
  description="正在完成、已经完成和暂时搁置的项目。"
>
  <SectionHeader
    eyebrow="Archive drawer / 01"
    title="Projects"
    description="一些正在完成、已经完成和暂时搁置的项目。"
  />
  {
    projects.length > 0 ? (
      <div class="projects-layout">
        <SectionIndex
          title="Project Index"
          groups={taxonomy}
          filterRoot="projects"
          total={projects.length}
        />
        <div class="projects-layout__content">
          <FeaturedProjects projects={featuredProjects} filterRoot="projects" />
          <section
            class="projects-index"
            aria-labelledby="all-projects-title"
            data-filter-section="projects"
          >
            <header>
              <h2 id="all-projects-title">Project Archive</h2>
              <span>
                {regularProjects.length.toString().padStart(2, "0")} secondary files
              </span>
            </header>
            <ProjectGrid projects={regularProjects} filterRoot="projects" />
          </section>
        </div>
      </div>
    ) : (
      <EmptyState
        title="New project slots are waiting."
        description="项目档案暂未写入，稍后再来读取。"
        variant="pixel"
      />
    )
  }
</BaseLayout>

<style>
  .projects-layout {
    display: grid;
    grid-template-columns: minmax(10rem, 12rem) minmax(0, 1fr);
    align-items: start;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .projects-layout__content {
    min-width: 0;
  }

  .projects-index > header {
    display: grid;
    margin-bottom: 1.4rem;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 0.25rem 1rem;
  }

  .projects-index h2 {
    margin-bottom: 0;
    font-size: clamp(1.8rem, 5vw, 2.7rem);
    letter-spacing: -0.05em;
  }

  .projects-index > header span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    grid-column: 2;
  }

  @media (max-width: 32rem) {
    .projects-index > header {
      grid-template-columns: 1fr;
    }

    .projects-index > header span {
      margin-top: 0.35rem;
      grid-column: 1;
      grid-row: auto;
    }
  }

  @media (max-width: 54rem) {
    .projects-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
