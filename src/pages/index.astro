---
import ArchiveTerminal from "../components/home/ArchiveTerminal.astro";
import SaveSlots from "../components/home/SaveSlots.astro";
import StatusBar from "../components/home/StatusBar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { navigation } from "../data/navigation";

const menuItems = navigation
  .filter((item) => item.href !== "/")
  .map((item) => ({
    ...item,
    description: {
      Projects: "Builds, tools and works in progress.",
      Notes: "Articles, logs and learning records.",
      Archive: "Milestones and saved moments.",
      Lab: "Pixel, UI and visual experiments.",
      About: "A short note about this archive.",
    }[item.label],
  }));

const saveSlots = [
  {
    slotNumber: "01",
    title: "Project Slot",
    status: "building",
    description: "Structures are ready. Project files will be loaded later.",
    href: "/projects/",
    active: true,
  },
  {
    slotNumber: "02",
    title: "Research Slot",
    status: "locked",
    description: "Notes and reading records are waiting for the next phase.",
    href: "/notes/",
  },
  {
    slotNumber: "03",
    title: "Lab Slot",
    status: "empty",
    description: "A reserved space for small visual and interface experiments.",
    href: "/lab/",
  },
];
---

<BaseLayout>
  <div class="home">
    <div class="home__rail home__rail--left" aria-hidden="true">
      <span>PA</span><i></i><i></i><i></i><span>08</span>
    </div>
    <div class="home__rail home__rail--right" aria-hidden="true">
      <span>IDX</span><i></i><i></i><i></i><span>Q</span>
    </div>
    <ArchiveTerminal
      title="Pixel Archive"
      statusText="archive online"
      menuItems={menuItems}
    />
    <StatusBar
      items={["building personal website", "mode quiet", "index ready"]}
    />
    <SaveSlots slots={saveSlots} />
  </div>
</BaseLayout>

<style>
  .home {
    position: relative;
    isolation: isolate;
  }

  .home::before {
    position: absolute;
    z-index: -2;
    top: -2rem;
    right: -1rem;
    bottom: 30%;
    left: -1rem;
    background-image:
      radial-gradient(var(--color-grid-strong) 1px, transparent 1px),
      linear-gradient(90deg, transparent 49.8%, var(--color-grid) 50%);
    background-size:
      16px 16px,
      100% 100%;
    content: "";
    mask-image:
      linear-gradient(to bottom, black 0 68%, transparent 94%),
      linear-gradient(to right, transparent, black 8% 92%, transparent);
    mask-composite: intersect;
    opacity: 0.7;
    pointer-events: none;
    animation: archive-grid-drift 18s ease-in-out infinite alternate;
  }

  .home::after {
    position: absolute;
    z-index: -1;
    top: -0.75rem;
    right: 0;
    left: 0;
    height: var(--pixel-unit);
    background:
      repeating-linear-gradient(
        90deg,
        var(--color-border-strong) 0 16px,
        transparent 16px 24px,
        var(--color-pixel-mark) 24px 28px,
        transparent 28px 44px
      );
    content: "";
    opacity: 0.45;
    pointer-events: none;
  }

  .home__rail {
    position: absolute;
    z-index: 0;
    top: 5.5rem;
    display: grid;
    width: 1.5rem;
    height: 20rem;
    grid-template-rows: auto repeat(3, 1fr) auto;
    justify-items: center;
    align-items: center;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.08em;
    opacity: 0.62;
    pointer-events: none;
  }

  .home__rail i {
    width: 1px;
    height: 100%;
    background:
      repeating-linear-gradient(
        to bottom,
        var(--color-border-strong) 0 8px,
        transparent 8px 14px
      );
  }

  .home__rail span {
    padding-block: 0.35rem;
    background: var(--color-bg);
    writing-mode: vertical-rl;
  }

  .home__rail--left {
    left: -3.25rem;
  }

  .home__rail--right {
    right: -3.25rem;
  }

  @keyframes archive-grid-drift {
    from {
      background-position:
        0 0,
        center;
    }

    to {
      background-position:
        2px 1px,
        calc(50% + 1px) center;
    }
  }

  @media (max-width: 74rem) {
    .home::before {
      right: 0;
      left: 0;
    }

    .home__rail {
      display: none;
    }
  }
</style>
