---
import ArchiveTerminal from "../components/home/ArchiveTerminal.astro";
import SaveSlots from "../components/home/SaveSlots.astro";
import StatusBar from "../components/home/StatusBar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { navigation } from "../data/navigation";

const menuItems = navigation
  .filter((item) => item.href !== "/")
  .map((item) => ({
    ...item,
    description: {
      Projects: "Builds, tools and works in progress.",
      Notes: "Articles, logs and learning records.",
      Archive: "Milestones and saved moments.",
      Lab: "Pixel, UI and visual experiments.",
      About: "A short note about this archive.",
    }[item.label],
  }));

const saveSlots = [
  {
    slotNumber: "01",
    title: "Project Slot",
    status: "building",
    description: "Structures are ready. Project files will be loaded later.",
    href: "/projects/",
    active: true,
  },
  {
    slotNumber: "02",
    title: "Research Slot",
    status: "locked",
    description: "Notes and reading records are waiting for the next phase.",
    href: "/notes/",
  },
  {
    slotNumber: "03",
    title: "Lab Slot",
    status: "empty",
    description: "A reserved space for small visual and interface experiments.",
    href: "/lab/",
  },
];
---

<BaseLayout>
  <div class="home">
    <span class="home__coordinate home__coordinate--left" aria-hidden="true">
      ARCHIVE / 00—08
    </span>
    <span class="home__coordinate home__coordinate--right" aria-hidden="true">
      INDEX / QUIET
    </span>
    <ArchiveTerminal
      title="Pixel Archive"
      statusText="archive online"
      menuItems={menuItems}
    />
    <StatusBar
      items={["building personal website", "mode quiet", "index ready"]}
    />
    <SaveSlots slots={saveSlots} />
  </div>
</BaseLayout>

<style>
  .home {
    position: relative;
    isolation: isolate;
  }

  .home::before {
    position: absolute;
    z-index: -2;
    top: -2rem;
    right: -1rem;
    bottom: 30%;
    left: -1rem;
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--color-border) 28%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-border) 28%, transparent) 1px,
        transparent 1px
      );
    background-size: 24px 24px;
    content: "";
    mask-image: linear-gradient(to bottom, black, transparent 88%);
    opacity: 0.5;
    pointer-events: none;
  }

  .home::after {
    position: absolute;
    z-index: -1;
    top: -0.75rem;
    right: 0;
    left: 0;
    height: 1px;
    background:
      repeating-linear-gradient(
        90deg,
        var(--color-border-strong) 0 12px,
        transparent 12px 22px
      );
    content: "";
    opacity: 0.45;
    pointer-events: none;
  }

  .home__coordinate {
    position: absolute;
    z-index: -1;
    top: 13rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    opacity: 0.45;
    writing-mode: vertical-rl;
  }

  .home__coordinate--left {
    left: -1.5rem;
    transform: rotate(180deg);
  }

  .home__coordinate--right {
    right: -1.5rem;
  }

  @media (max-width: 74rem) {
    .home::before {
      right: 0;
      left: 0;
    }

    .home__coordinate {
      display: none;
    }
  }
</style>
