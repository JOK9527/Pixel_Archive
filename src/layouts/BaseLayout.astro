---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { site } from "../data/site";
import "../styles/global.css";
import "../styles/markdown.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = site.name,
  description = site.description,
} = Astro.props;

const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f1e8" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><rect width=%2216%22 height=%2216%22 fill=%22%238b79b7%22/><rect x=%224%22 y=%224%22 width=%228%22 height=%228%22 fill=%22%23f6f1e8%22/></svg>"
    />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("pixel-archive-theme");
        document.documentElement.dataset.theme =
          storedTheme === "dark" ? "dark" : "light";
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <Header currentPath={currentPath} />
      <main class="site-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
