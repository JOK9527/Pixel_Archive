---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { site } from "../data/site";
import "../styles/global.css";
import "../styles/markdown.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  robots?: string;
};

const {
  title = site.name,
  description = site.description,
  image = site.defaultImage,
  type = "website",
  publishedTime,
  robots = "index, follow",
} = Astro.props;

const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const currentPath = Astro.url.pathname;
const firstSegment = currentPath.split("/").filter(Boolean)[0];
const section =
  currentPath === "/"
    ? "home"
    : firstSegment?.startsWith("404")
      ? "error"
      : firstSegment || "home";
const canonicalUrl = site.url
  ? new URL(currentPath, `${site.url}/`).toString()
  : undefined;
const socialImage = site.url
  ? new URL(image, `${site.url}/`).toString()
  : image;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f8f5f0" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} Notes`}
      href="/rss.xml"
    />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {
      type === "article" &&
        publishedTime && (
          <meta property="article:published_time" content={publishedTime} />
        )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico?v=2" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("pixel-archive-theme");
        document.documentElement.dataset.theme =
          storedTheme === "dark" ? "dark" : "light";
      })();
    </script>
  </head>
  <body data-section={section}>
    <div class="site-shell">
      <Header currentPath={currentPath} />
      <main class="site-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
