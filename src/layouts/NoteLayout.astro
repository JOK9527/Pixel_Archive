---
import { getEntry } from "astro:content";
import MarkdownContent from "../components/notes/MarkdownContent.astro";
import NoteMeta from "../components/notes/NoteMeta.astro";
import OnThisPage from "../components/notes/OnThisPage.astro";
import type { NoteItem } from "../lib/content/notes";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  note: NoteItem;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  newerNote?: NoteItem;
  olderNote?: NoteItem;
};

const {
  note,
  headings = [],
  newerNote,
  olderNote,
} = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const relatedProjects = (
  await Promise.all(
    note.relatedProjects.map(async (slug) => {
      const entry = await getEntry("projects", slug);
      return entry
        ? { href: `/projects/${slug}/`, title: entry.data.title }
        : undefined;
    }),
  )
).filter((item) => item !== undefined);
const relatedArchive = (
  await Promise.all(
    note.relatedArchive.map(async (slug) => {
      const entry = await getEntry("archive", slug);
      return entry
        ? { href: `/archive/#${slug}`, title: entry.data.title }
        : undefined;
    }),
  )
).filter((item) => item !== undefined);
---

<BaseLayout
  title={note.title}
  description={note.description}
  type="article"
  publishedTime={`${note.date}T00:00:00Z`}
  image={note.cover}
>
  <article class="note-detail">
    <a class="note-detail__back" href="/notes/">← Notes archive</a>
    <header>
      <NoteMeta
        type={note.type}
        category={note.category}
        date={note.date}
        updated={note.updated}
      />
      <h1>{note.title}</h1>
      {note.description && <p>{note.description}</p>}
      {
        note.tags.length > 0 && (
          <ul aria-label="Note tags">
            {note.tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )
      }
    </header>

    <div class="note-detail__reading">
      {
        tocHeadings.length > 0 && (
          <OnThisPage headings={tocHeadings} />
        )
      }

      <div class="note-detail__body" data-reading-content>
        <MarkdownContent>
          <slot />
        </MarkdownContent>

        {
          (relatedProjects.length > 0 || relatedArchive.length > 0) && (
            <aside class="note-detail__related" aria-labelledby="related-records-title">
              <h2 id="related-records-title">Related records</h2>
              <div>
                {relatedProjects.map((item) => (
                  <a href={item.href}>
                    <span>PROJECT</span>
                    <strong>{item.title}</strong>
                  </a>
                ))}
                {relatedArchive.map((item) => (
                  <a href={item.href}>
                    <span>SAVE POINT</span>
                    <strong>{item.title}</strong>
                  </a>
                ))}
              </div>
            </aside>
          )
        }

        {
          (newerNote || olderNote) && (
            <nav class="note-detail__pager" aria-label="Adjacent notes">
              {newerNote ? (
                <a href={newerNote.href}>
                  <span>← Newer note</span>
                  <strong>{newerNote.title}</strong>
                </a>
              ) : (
                <span></span>
              )}
              {olderNote && (
                <a href={olderNote.href}>
                  <span>Older note →</span>
                  <strong>{olderNote.title}</strong>
                </a>
              )}
            </nav>
          )
        }
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .note-detail {
    max-width: 64rem;
    margin-inline: auto;
  }

  .note-detail__back {
    display: inline-block;
    margin-bottom: 2.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .note-detail > header {
    max-width: var(--measure-wide);
    margin-bottom: clamp(3rem, 8vw, 5rem);
    margin-inline: auto;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .note-detail h1 {
    max-width: var(--measure-display);
    margin-block: 1rem;
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    letter-spacing: -0.055em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .note-detail > header > p {
    max-width: var(--measure-narrow);
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2.5vw, 1.16rem);
  }

  .note-detail > header > ul {
    display: flex;
    margin: 1rem 0 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 0.55rem;
    color: var(--color-purple);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    list-style: none;
  }

  .note-detail__reading {
    display: grid;
    grid-template-columns: 11rem minmax(0, var(--reading-width));
    gap: clamp(2rem, 6vw, 4rem);
    justify-content: center;
    align-items: start;
  }

  .note-detail__body {
    min-width: 0;
  }

  .note-detail__pager {
    display: grid;
    margin-top: 4rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .note-detail__related {
    margin-top: 3.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .note-detail__related h2 {
    margin-bottom: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .note-detail__related > div {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .note-detail__related a {
    display: grid;
    min-width: 0;
    padding: 0.8rem;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-raised);
    color: var(--color-text);
    gap: 0.35rem;
    text-decoration: none;
  }

  .note-detail__related span {
    color: var(--section-accent);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .note-detail__related strong {
    overflow-wrap: anywhere;
    font-size: 0.82rem;
  }

  .note-detail__pager a {
    display: grid;
    min-width: 0;
    padding: 0.9rem;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-raised);
    color: var(--color-text);
    gap: 0.35rem;
    text-decoration: none;
  }

  .note-detail__pager a:last-child {
    text-align: right;
  }

  .note-detail__pager span {
    color: var(--section-accent);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .note-detail__pager strong {
    overflow-wrap: anywhere;
    font-size: 0.84rem;
  }

  @media (max-width: 52rem) {
    .note-detail__reading {
      grid-template-columns: minmax(0, var(--reading-width));
    }

  }

  @media (max-width: 34rem) {
    .note-detail h1 {
      max-width: none;
      font-size: clamp(2.35rem, 12vw, 3rem);
      line-height: 1.06;
    }

    .note-detail__pager,
    .note-detail__related > div {
      grid-template-columns: 1fr;
    }

    .note-detail__pager > span {
      display: none;
    }

    .note-detail__pager a:last-child {
      text-align: left;
    }
  }
</style>
