---
import LabTypeBadge from "../components/lab/LabTypeBadge.astro";
import MarkdownContent from "../components/notes/MarkdownContent.astro";
import PixelCover from "../components/cover/PixelCover.astro";
import type { LabItem } from "../lib/content/lab";
import { normalizeCoverMeta } from "../lib/visual/pixel-cover-system";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  item: LabItem;
};

const { item } = Astro.props;
const coverRecipe = normalizeCoverMeta({
  kind: "lab",
  title: item.title,
  seed: item.slug,
  date: item.date,
  status: item.status,
  tagCount: item.tags.length,
  coverMeta: { density: "high" },
});
---

<BaseLayout title={item.title} description={item.description}>
  <article class="lab-detail">
    <a class="lab-detail__back" href="/lab/">← LAB INDEX</a>

    <header class="lab-detail__header">
      <div class="lab-detail__meta">
        <LabTypeBadge type={item.type} />
        <span class:list={["lab-detail__status", `lab-detail__status--${item.status}`]}>
          {item.status}
        </span>
        {item.date && <time datetime={item.date}>{item.date}</time>}
      </div>
      <h1>{item.title}</h1>
      <p>{item.description}</p>
      {
        item.tags.length > 0 && (
          <ul aria-label="Lab tags">
            {item.tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )
      }
    </header>

    <div class="lab-detail__frame">
      {
        item.cover ? (
          <img src={item.cover} alt="" loading="eager" />
        ) : (
          <PixelCover
            kind="lab"
            variant={coverRecipe.variant}
            code={coverRecipe.code}
            title={item.title}
            subtitle={item.description}
            meta={[item.type]}
            tags={item.tags}
            status={item.status}
            progress={coverRecipe.progress}
            date={item.date}
            seed={coverRecipe.seed}
            accent={coverRecipe.accent}
            density={coverRecipe.density}
            showHeat={coverRecipe.showHeat}
            label="EXPERIMENT CODE"
          />
        )
      }
    </div>

    <div class="lab-detail__body">
      <aside aria-label="Experiment metadata">
        <h2>Record</h2>
        <dl>
          <dt>Type</dt>
          <dd>{item.type}</dd>
          <dt>Status</dt>
          <dd>{item.status}</dd>
          {item.date && <><dt>Date</dt><dd>{item.date}</dd></>}
        </dl>
      </aside>
      <MarkdownContent>
        <slot />
      </MarkdownContent>
    </div>
  </article>
</BaseLayout>

<style>
  .lab-detail {
    max-width: 62rem;
    margin-inline: auto;
  }

  .lab-detail__back {
    display: inline-block;
    margin-bottom: 2.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .lab-detail__back:hover {
    color: var(--section-accent);
  }

  .lab-detail__header {
    max-width: var(--measure-wide);
    margin-bottom: 2.5rem;
  }

  .lab-detail__meta {
    display: flex;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .lab-detail__meta time,
  .lab-detail__status {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .lab-detail__status {
    padding: 0.28rem 0.48rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface-soft);
  }

  .lab-detail__status--done {
    border-color: color-mix(in srgb, var(--color-status) 38%, var(--color-border));
    background: var(--color-status-soft);
    color: var(--color-status);
  }

  .lab-detail h1 {
    max-width: var(--measure-display);
    margin-bottom: 1rem;
    font-size: clamp(2.7rem, 9vw, 5.8rem);
    letter-spacing: -0.07em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .lab-detail__header > p {
    max-width: var(--measure-narrow);
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2.5vw, 1.18rem);
  }

  .lab-detail__header ul {
    display: flex;
    margin: 1rem 0 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 0.55rem;
    color: var(--color-violet);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    list-style: none;
  }

  .lab-detail__frame {
    margin-bottom: clamp(2.5rem, 7vw, 4.5rem);
  }

  .lab-detail__frame > img,
  .lab-detail__frame > :global(.pixel-cover-system) {
    width: 100%;
    min-height: clamp(15rem, 34vw, 23rem);
    border: 1px solid var(--color-border-strong);
    box-shadow: var(--shadow-pixel-violet), var(--shadow-md);
  }

  .lab-detail__frame > img {
    object-fit: cover;
  }

  .lab-detail__body {
    display: grid;
    grid-template-columns: minmax(9rem, 12rem) minmax(0, var(--reading-width));
    align-items: start;
    justify-content: center;
    gap: clamp(2rem, 7vw, 5rem);
  }

  .lab-detail__body > aside {
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
  }

  .lab-detail__body > aside h2 {
    margin-bottom: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lab-detail__body dl {
    display: grid;
    margin: 0;
    grid-template-columns: auto 1fr;
    gap: 0.35rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .lab-detail__body dt {
    color: var(--color-text-muted);
  }

  .lab-detail__body dd {
    margin: 0;
    overflow-wrap: anywhere;
  }

  @media (max-width: 44rem) {
    .lab-detail__body {
      grid-template-columns: 1fr;
    }

    .lab-detail__frame {
      margin-inline: calc(var(--pixel-unit) * 0.5);
    }
  }
</style>
