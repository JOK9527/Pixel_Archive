---
import type { NoteTypeValue } from "../../lib/content/notes";
import {
  normalizeCoverMeta,
  type CoverMeta,
} from "../../lib/visual/pixel-cover-system";
import PixelCover from "../cover/PixelCover.astro";
import NoteMeta from "./NoteMeta.astro";

type Props = {
  slug: string;
  title: string;
  description?: string;
  type: NoteTypeValue;
  category: string;
  tags?: string[];
  date: string;
  updated?: string;
  href: string;
  cover?: string;
  coverMeta?: CoverMeta;
};

const {
  slug,
  title,
  description,
  type,
  category,
  tags = [],
  date,
  updated,
  href,
  cover,
  coverMeta,
} = Astro.props;
const coverRecipe = normalizeCoverMeta({
  kind: "note",
  title,
  seed: slug,
  date,
  status: type,
  tagCount: tags.length,
  coverMeta,
});
---

<article class="note-card">
  <a href={href} aria-label={`Read note: ${title}`}>
    <div
      class:list={[
        "note-card__cover",
        { "note-card__cover--generated": !cover },
      ]}
    >
      {
        cover ? (
          <img src={cover} alt="" loading="lazy" />
        ) : (
          <PixelCover
            kind="note"
            variant={coverRecipe.variant}
            code={coverRecipe.code}
            title={title}
            meta={[category, type]}
            status={type}
            tags={tags}
            progress={coverRecipe.progress}
            date={date.replaceAll("-", ".")}
            seed={coverRecipe.seed}
            accent={coverRecipe.accent}
            density={coverRecipe.density}
            showHeat={coverRecipe.showHeat}
            compact
            label={type.toUpperCase()}
          />
        )
      }
    </div>
    <div class="note-card__body">
      <NoteMeta type={type} category={category} date={date} updated={updated} />
      <h2>{title}</h2>
      {description && <p>{description}</p>}
      {
        tags.length > 0 && (
          <ul aria-label="Note tags">
            {tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )
      }
      <span class="note-card__action ui-label">OPEN NOTE →</span>
    </div>
  </a>
</article>

<style>
  .note-card {
    border-top: 1px solid var(--color-border);
  }

  .note-card:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .note-card > a {
    display: grid;
    padding-block: var(--space-5);
    color: var(--color-text);
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-4) var(--space-6);
    text-decoration: none;
    transition:
      padding-inline var(--transition-fast),
      background-color var(--transition-fast);
  }

  .note-card > a:hover,
  .note-card > a:focus-visible {
    padding-inline: 1rem;
    background: color-mix(
      in srgb,
      var(--color-surface-raised) 82%,
      var(--section-soft)
    );
  }

  .note-card__cover {
    width: 11rem;
    min-height: 7rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    grid-column: 2;
    grid-row: 1;
  }

  .note-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .note-card__cover--generated :global(.pixel-cover),
  .note-card__cover--generated :global(.pixel-cover-system) {
    min-height: 9rem;
  }

  .note-card__body {
    min-width: 0;
    grid-column: 1;
    grid-row: 1;
  }

  .note-card h2 {
    margin-block: var(--space-3) var(--space-2);
    font-size: clamp(1.35rem, 4vw, 1.8rem);
    letter-spacing: -0.04em;
    line-height: 1.15;
    color: var(--color-heading);
  }

  .note-card p {
    max-width: 34rem;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
  }

  .note-card ul {
    display: flex;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-primary);
    font-family: var(--font-ui);
    font-size: 0.65rem;
    list-style: none;
  }

  .note-card__action {
    display: inline-block;
    margin-top: var(--space-5);
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 38rem) {
    .note-card > a {
      grid-template-columns: 1fr;
    }

    .note-card__cover,
    .note-card__body {
      grid-column: 1;
    }

    .note-card__cover {
      width: 100%;
      max-height: 10rem;
      grid-row: 1;
    }

    .note-card__body {
      grid-row: 2;
    }

    .note-card__cover--generated {
      display: none;
    }

    .note-card__cover--generated + .note-card__body {
      grid-row: 1;
    }
  }
</style>
