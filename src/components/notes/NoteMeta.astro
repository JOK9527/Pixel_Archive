---
import type { NoteTypeValue } from "../../lib/content/notes";
import NoteTypeBadge from "./NoteTypeBadge.astro";

type Props = {
  type: NoteTypeValue;
  category: string;
  date: string;
  updated?: string;
};

const { type, category, date, updated } = Astro.props;
---

<div class="note-meta">
  <div class="note-meta__primary">
    <NoteTypeBadge type={type} />
    <span>{category}</span>
    <time datetime={date}>{date}</time>
  </div>
  {
    updated && (
      <div class="note-meta__secondary">
        <span>UPDATED</span>
        <time datetime={updated}>{updated}</time>
      </div>
    )
  }
</div>

<style>
  .note-meta {
    display: grid;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.67rem;
  }

  .note-meta__primary,
  .note-meta__secondary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .note-meta__primary > span {
    color: var(--color-text);
    font-weight: 700;
  }

  .note-meta__primary time,
  .note-meta__secondary time {
    color: var(--color-text-muted);
  }

  .note-meta__secondary {
    color: var(--color-text-faint);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
  }

  .note-meta__secondary span {
    color: var(--section-accent);
    font-weight: 700;
  }
</style>
