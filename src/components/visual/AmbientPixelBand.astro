---
import {
  generateAmbientBandModel,
  type AmbientBandIntensity,
  type AmbientBandPlacement,
  type AmbientBandSection,
  type AmbientBandVariant,
} from "../../lib/visual/ambient-band";
import "../../styles/ambient-band.css";

type Props = {
  section: AmbientBandSection;
  seed: string;
  variant?: AmbientBandVariant;
  intensity?: AmbientBandIntensity;
  placement?: AmbientBandPlacement;
  enabled?: boolean;
};

const {
  section,
  seed,
  variant = "auto",
  intensity = "low",
  placement = "article-detail",
  enabled = true,
} = Astro.props;

const model = generateAmbientBandModel({ seed, variant });
const id = `ambient-${section}-${seed}`
  .replace(/[^a-z0-9-]/gi, "-")
  .toLowerCase();
---

{
  enabled && (
    <div
      class:list={[
        "ambient-band",
        `ambient-band--${model.variant}`,
        `ambient-band--${intensity}`,
        `ambient-band--${placement}`,
      ]}
      aria-hidden="true"
      data-ambient-band
      data-ambient-section={section}
      data-ambient-seed={seed}
      data-ambient-variant={model.variant}
    >
      <svg
        class="ambient-band__svg"
        viewBox="0 0 560 300"
        focusable="false"
      >
        <defs>
          <linearGradient
            id={`${id}-gradient`}
            x1={model.gradient.x1}
            y1={model.gradient.y1}
            x2={model.gradient.x2}
            y2={model.gradient.y2}
          >
            <stop offset="0%" stop-color="var(--ambient-a)" />
            <stop offset="54%" stop-color="var(--ambient-b)" />
            <stop offset="100%" stop-color="var(--ambient-c)" />
          </linearGradient>
          <pattern
            id={`${id}-pixels`}
            width="16"
            height="16"
            patternUnits="userSpaceOnUse"
          >
            <rect width="5" height="5" fill="var(--ambient-pixel)" />
            <rect x="10" y="10" width="3" height="3" fill="var(--ambient-pixel)" />
          </pattern>
          <clipPath id={`${id}-clip`}>
            <polygon points={model.mainPoints} />
          </clipPath>
        </defs>

        <polygon
          class="ambient-band__base"
          points={model.mainPoints}
          fill={`url(#${id}-gradient)`}
        />
        <rect
          class="ambient-band__texture"
          width="560"
          height="300"
          fill={`url(#${id}-pixels)`}
          clip-path={`url(#${id}-clip)`}
        />
        <polygon
          class="ambient-band__facet"
          points={model.facetPoints}
          fill="var(--ambient-facet)"
        />
        {
          model.secondaryPoints && (
            <polygon
              class="ambient-band__secondary"
              points={model.secondaryPoints}
              fill={`url(#${id}-gradient)`}
            />
          )
        }
        {
          model.nodes.map((node) => (
            <rect
              class:list={[
                "ambient-band__node",
                { "ambient-band__node--hot": node.hot },
              ]}
              x={node.x}
              y={node.y}
              width={node.size}
              height={node.size}
            />
          ))
        }
      </svg>
    </div>
  )
}
