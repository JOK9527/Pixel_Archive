---
import {
  createAmbientBandModel,
  type AmbientBandIntensity,
  type AmbientBandSection,
  type AmbientBandVariant,
} from "../../lib/visual/ambient-band";
import "../../styles/ambient-band.css";

type Props = {
  section: AmbientBandSection;
  variant: AmbientBandVariant;
  seed?: string;
  intensity?: AmbientBandIntensity;
  maxWidth?: number;
  debug?: boolean;
};

const {
  section,
  variant,
  seed = `${section}-${variant}`,
  intensity = "medium",
  maxWidth = 760,
  debug = false,
} = Astro.props;
const model = createAmbientBandModel({ section, variant, seed });
const clipId = `${model.id}-clip`;
const patternId = `${model.id}-grid`;
---

<figure
  class:list={[
    "ambient-pixel-band",
    `ambient-pixel-band--${section}`,
    `ambient-pixel-band--${variant}`,
    `ambient-pixel-band--${intensity}`,
    { "ambient-pixel-band--debug": debug },
  ]}
  style={`--ambient-max-width: ${maxWidth}px`}
  data-section={section}
  data-variant={variant}
  data-seed={seed}
  aria-label={`${section} ${variant} ambient pixel band`}
>
  <svg
    viewBox="0 0 860 320"
    role="img"
    aria-labelledby={`${model.id}-title ${model.id}-description`}
    preserveAspectRatio="xMidYMid meet"
  >
    <title id={`${model.id}-title`}>{section} {variant} ambient band</title>
    <desc id={`${model.id}-description`}>
      A deterministic geometric pixel ribbon with facets, a clipped grid and
      edge pixels.
    </desc>
    <defs>
      <clipPath id={clipId}>
        <polygon points={model.silhouette} />
      </clipPath>
      <pattern
        id={patternId}
        width="24"
        height="24"
        patternUnits="userSpaceOnUse"
      >
        <path d="M 24 0 L 0 0 0 24" class="ambient-pixel-band__grid-line" />
        <rect
          x="16"
          y="16"
          width="5"
          height="5"
          class="ambient-pixel-band__grid-node"
        />
      </pattern>
    </defs>

    <g class="ambient-pixel-band__geometry">
      <polygon
        points={model.silhouette}
        class="ambient-pixel-band__silhouette"
      />
      {
        model.facets.map((points, index) => (
          <polygon
            points={points}
            class={`ambient-pixel-band__facet ambient-pixel-band__facet--${(index % 4) + 1}`}
          />
        ))
      }
    </g>

    <rect
      width="860"
      height="320"
      fill={`url(#${patternId})`}
      clip-path={`url(#${clipId})`}
      class="ambient-pixel-band__grid"
    />

    <g class="ambient-pixel-band__pixels" aria-hidden="true">
      {
        model.pixels.map((pixel) => (
          <rect
            x={pixel.x}
            y={pixel.y}
            width={pixel.size}
            height={pixel.size}
            class={`ambient-pixel-band__pixel ambient-pixel-band__pixel--${pixel.tone}`}
          />
        ))
      }
    </g>
  </svg>

  <div class="ambient-pixel-band__debug" aria-hidden="true">
    <span>860 × 320</span>
    <span>{maxWidth}px max</span>
  </div>
</figure>
