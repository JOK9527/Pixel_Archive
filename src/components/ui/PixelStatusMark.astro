---
type Props = {
  status?: string;
};

const { status = "ready" } = Astro.props;
const normalized = status.toLowerCase();
const strength = ["done", "ready", "active"].includes(normalized)
  ? 3
  : ["wip", "building", "prototype"].includes(normalized)
    ? 2
    : 1;
---

<span class="pixel-status-mark" aria-label={status}>
  {Array.from({ length: 3 }, (_, index) => <i data-active={index < strength}></i>)}
</span>

<style>
  .pixel-status-mark {
    display: inline-flex;
    align-items: end;
    gap: 2px;
  }

  .pixel-status-mark i {
    width: var(--pixel-unit);
    height: var(--pixel-unit);
    background: var(--color-border-strong);
  }

  .pixel-status-mark i:nth-child(2) {
    height: calc(var(--pixel-unit) * 2);
  }

  .pixel-status-mark i:nth-child(3) {
    height: calc(var(--pixel-unit) * 3);
  }

  .pixel-status-mark i[data-active="true"] {
    background: var(--cover-accent, var(--section-accent));
  }
</style>
