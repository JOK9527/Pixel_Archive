---
type Props = {
  label: string;
  tone?: "neutral" | "green" | "purple" | "warning";
  pulse?: boolean;
};

const {
  label,
  tone = "neutral",
  pulse = false,
} = Astro.props;
---

<span class:list={["status-pill", `status-pill--${tone}`]}>
  <span class:list={["status-pill__signal", { "status-pill__signal--pulse": pulse }]} aria-hidden="true">
    <i></i><i></i><i></i>
  </span>
  {label}
</span>

<style>
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .status-pill--green {
    color: var(--color-green);
  }

  .status-pill--purple {
    color: var(--color-purple);
  }

  .status-pill--warning {
    color: var(--color-warning);
  }

  .status-pill__signal {
    display: flex;
    width: calc(var(--pixel-unit) * 3);
    height: calc(var(--pixel-unit) * 2);
    flex: 0 0 auto;
    align-items: flex-end;
    gap: 1px;
  }

  .status-pill__signal i {
    width: var(--pixel-unit);
    background: currentColor;
  }

  .status-pill__signal i:nth-child(1) {
    height: var(--pixel-unit);
    opacity: 0.55;
  }

  .status-pill__signal i:nth-child(2) {
    height: calc(var(--pixel-unit) * 2);
  }

  .status-pill__signal i:nth-child(3) {
    height: var(--pixel-unit);
    opacity: 0.75;
  }

  .status-pill__signal--pulse {
    animation: status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%,
    100% {
      opacity: 0.55;
    }

    50% {
      opacity: 1;
    }
  }
</style>
