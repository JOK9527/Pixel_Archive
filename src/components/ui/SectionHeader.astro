---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
};

const {
  eyebrow,
  title,
  description,
  align = "left",
} = Astro.props;
---

<header class:list={["section-header", `section-header--${align}`]}>
  {eyebrow && <p class="section-header__eyebrow ui-label">{eyebrow}</p>}
  <h1>{title}</h1>
  {description && <p class="section-header__description">{description}</p>}
</header>

<style>
  .section-header {
    max-width: var(--measure-reading);
    margin-bottom: var(--space-8);
  }

  .section-header::after {
    display: block;
    width: min(12rem, 45%);
    height: var(--pixel-unit);
    margin-top: var(--space-5);
    background:
      repeating-linear-gradient(
        90deg,
        var(--section-main) 0 12px,
        transparent 12px 18px,
        var(--section-neutral) 18px 26px,
        transparent 26px 32px,
        var(--section-cool) 32px 38px,
        transparent 38px 44px,
        var(--section-peak) 44px 48px,
        transparent 48px 58px
      );
    content: "";
    opacity: 0.6;
  }

  .section-header--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-header--center::after {
    margin-inline: auto;
  }

  .section-header__eyebrow {
    margin-bottom: var(--space-3);
    color: var(--section-accent);
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: var(--tracking-ui);
    text-transform: uppercase;
  }

  .section-header h1 {
    margin-bottom: var(--space-3);
    font-size: clamp(2.7rem, 8vw, 5.6rem);
    letter-spacing: -0.065em;
    line-height: 0.95;
  }

  .section-header__description {
    max-width: var(--measure-narrow);
    margin-bottom: 0;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2.5vw, 1.15rem);
  }

  .section-header--center .section-header__description {
    margin-inline: auto;
  }

  @media (max-width: 42rem) {
    .section-header {
      margin-bottom: var(--space-7);
    }
  }
</style>
