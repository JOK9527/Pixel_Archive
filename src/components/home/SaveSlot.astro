---
import StatusPill from "../ui/StatusPill.astro";

type Props = {
  slotNumber: string;
  title: string;
  status: string;
  description?: string;
  href?: string;
  active?: boolean;
};

const {
  slotNumber,
  title,
  status,
  description,
  href,
  active = false,
} = Astro.props;

const tone = active
  ? "green"
  : status === "locked"
    ? "warning"
    : status === "empty"
      ? "purple"
      : "neutral";
const Element = href ? "a" : "article";
---

<Element
  class:list={["save-slot", "pixel-corner", { "save-slot--active": active }]}
  href={href}
  data-status={status}
>
  <div class="save-slot__header">
    <span>SAVE SLOT {slotNumber}</span>
    <StatusPill label={status} tone={tone} pulse={active} />
  </div>
  <div class="save-slot__screen" aria-hidden="true">
    <div class="save-slot__chip">
      <span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
    </div>
    <div class="save-slot__tracks">
      <i></i><i></i><i></i>
    </div>
  </div>
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  <span class="save-slot__action">{href ? "load slot →" : "slot waiting"}</span>
</Element>

<style>
  .save-slot {
    --card-accent: var(--color-violet);
    --card-pixel-shadow: var(--shadow-pixel-violet);

    display: flex;
    min-width: 0;
    min-height: 16rem;
    padding: 1.15rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
    color: var(--color-text);
    flex-direction: column;
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .save-slot:hover,
  .save-slot:focus-visible {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md), var(--card-pixel-shadow);
    color: var(--color-text);
    transform: translate(-1px, -1px);
  }

  .save-slot--active {
    --card-accent: var(--color-primary);
    --card-pixel-shadow: var(--shadow-pixel-green);

    box-shadow:
      inset 0 3px 0 var(--card-accent),
      var(--shadow-sm);
  }

  .save-slot[data-status="locked"] {
    --card-accent: var(--color-warm);
    --card-pixel-shadow: var(--shadow-pixel-amber);
  }

  .save-slot[data-status="empty"] {
    --card-accent: var(--color-violet);
    --card-pixel-shadow: var(--shadow-pixel-violet);
  }

  .save-slot__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .save-slot__screen {
    display: grid;
    height: 5.2rem;
    margin-block: 1.2rem;
    padding: 0.7rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-muted);
    background-image:
      linear-gradient(var(--color-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid) 1px, transparent 1px);
    background-size: 16px 16px;
    grid-template-columns: 1fr 1.4fr;
    align-items: center;
    gap: 0.8rem;
  }

  .save-slot__chip {
    display: grid;
    padding: 0.35rem;
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    box-shadow: var(--shadow-pixel-soft);
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }

  .save-slot__chip span {
    aspect-ratio: 1;
    background: var(--color-border);
  }

  .save-slot__chip span:nth-child(3n + 1) {
    background: var(--color-status);
  }

  .save-slot__chip span:nth-child(5n) {
    background: var(--color-accent);
  }

  .save-slot__tracks {
    display: grid;
    gap: 0.45rem;
  }

  .save-slot__tracks i {
    height: var(--pixel-unit);
    background: var(--color-border-strong);
  }

  .save-slot__tracks i:nth-child(1) {
    width: 100%;
  }

  .save-slot__tracks i:nth-child(2) {
    width: 72%;
    background: var(--color-pixel-mark);
  }

  .save-slot__tracks i:nth-child(3) {
    width: 42%;
    background: var(--color-tea);
  }

  .save-slot h3 {
    margin-bottom: 0.45rem;
    font-size: 1.05rem;
    color: var(--color-heading);
  }

  .save-slot p {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    font-size: 0.84rem;
  }

  .save-slot__action {
    margin-top: auto;
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
