---
import StatusPill from "../ui/StatusPill.astro";
import PixelCover from "../cover/PixelCover.astro";

type Props = {
  slotNumber: string;
  title: string;
  status: string;
  description?: string;
  href?: string;
  active?: boolean;
};

const {
  slotNumber,
  title,
  status,
  description,
  href,
  active = false,
} = Astro.props;

const tone = active
  ? "green"
  : status === "locked"
    ? "warning"
    : status === "empty"
      ? "purple"
      : "neutral";
const coverAccent = active
  ? "green"
  : status === "locked"
    ? "orange"
    : status === "empty"
      ? "purple"
      : "neutral";
const coverProgress = active
  ? 78
  : status === "locked"
    ? 8
    : status === "empty"
      ? 0
      : 45;
const Element = href ? "a" : "article";
---

<Element
  class:list={["save-slot", "pixel-corner", { "save-slot--active": active }]}
  href={href}
  data-status={status}
>
  <div class="save-slot__header">
    <span>SAVE SLOT {slotNumber}</span>
    <StatusPill label={status} tone={tone} />
  </div>
  <div class="save-slot__cover">
    <PixelCover
      kind="archive"
      variant="save-point"
      code={`S${slotNumber}`}
      title={title}
      meta={[status]}
      status={status}
      tags={[title, status]}
      progress={coverProgress}
      seed={`${slotNumber}-${title}`}
      accent={coverAccent}
      density="low"
      compact
      label="SAVE SLOT"
    />
  </div>
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  <span class="save-slot__action ui-label">{href ? "LOAD SLOT →" : "SLOT WAITING"}</span>
</Element>

<style>
  .save-slot {
    --card-accent: var(--color-violet);
    --card-pixel-shadow: var(--shadow-pixel-violet);

    display: flex;
    min-width: 0;
    min-height: 16rem;
    padding: 1.15rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
    color: var(--color-text);
    flex-direction: column;
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .save-slot:hover,
  .save-slot:focus-visible {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md), var(--card-pixel-shadow);
    color: var(--color-text);
    transform: translate(-1px, -1px);
  }

  .save-slot--active {
    --card-accent: var(--color-primary);
    --card-pixel-shadow: var(--shadow-pixel-green);

    box-shadow:
      inset 0 3px 0 var(--card-accent),
      var(--shadow-sm);
  }

  .save-slot[data-status="locked"] {
    --card-accent: var(--color-warm);
    --card-pixel-shadow: var(--shadow-pixel-amber);
  }

  .save-slot[data-status="empty"] {
    --card-accent: var(--color-violet);
    --card-pixel-shadow: var(--shadow-pixel-violet);
  }

  .save-slot__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .save-slot__cover {
    margin-block: 1.2rem;
    border: 1px solid var(--color-border);
  }

  .save-slot__cover > :global(.pixel-cover-system) {
    min-height: 7rem;
  }

  .save-slot h3 {
    margin-bottom: 0.45rem;
    font-size: 1.05rem;
    color: var(--color-heading);
  }

  .save-slot p {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    font-size: 0.84rem;
  }

  .save-slot__action {
    margin-top: auto;
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
