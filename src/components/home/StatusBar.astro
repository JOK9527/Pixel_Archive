---
import StatusPill from "../ui/StatusPill.astro";

type Props = {
  items: string[];
};

const { items } = Astro.props;

const tones = ["green", "purple", "warning"] as const;
---

<aside class="status-bar" aria-label="Archive status">
  <p>SYS.STATUS</p>
  <div class="status-bar__items">
    {
      items.map((item, index) => (
        <StatusPill
          label={item}
          tone={tones[index % tones.length]}
          pulse={index === 0}
        />
      ))
    }
  </div>
</aside>

<style>
  .status-bar {
    display: flex;
    margin-top: 1.25rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
  }

  .status-bar::before {
    width: 1.4rem;
    height: 2px;
    flex: 0 0 auto;
    background:
      repeating-linear-gradient(
        90deg,
        var(--color-pixel-mark) 0 4px,
        transparent 4px 7px
      );
    content: "";
  }

  .status-bar p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
  }

  .status-bar__items {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    gap: clamp(0.8rem, 3vw, 2rem);
    flex-wrap: wrap;
  }

  @media (max-width: 42rem) {
    .status-bar {
      align-items: flex-start;
      flex-direction: column;
    }

    .status-bar__items {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.7rem;
    }

  }
</style>
