---
type MenuItem = {
  label: string;
  href: string;
  description?: string;
};

type Props = {
  items: MenuItem[];
};

const { items } = Astro.props;
---

<nav class="home-menu" aria-label="Archive menu">
  <ol>
    {
      items.map((item, index) => (
        <li>
          <a href={item.href}>
            <span class="home-menu__index" aria-hidden="true">
              {String(index + 1).padStart(2, "0")}
            </span>
            <span class="home-menu__label">{item.label}</span>
            {item.description && (
              <span class="home-menu__description">{item.description}</span>
            )}
            <span class="home-menu__arrow" aria-hidden="true">
              →
            </span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .home-menu ol {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .home-menu li {
    border-top: 1px solid var(--color-border);
  }

  .home-menu li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .home-menu a {
    display: grid;
    grid-template-columns: 2rem minmax(6rem, 0.7fr) minmax(10rem, 1.3fr) auto;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 0.25rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      padding-inline var(--transition-fast);
  }

  .home-menu a:hover,
  .home-menu a:focus-visible {
    padding-inline: 0.65rem;
    background: var(--color-surface-muted);
  }

  .home-menu__index,
  .home-menu__arrow {
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .home-menu__label {
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .home-menu__index::after {
    display: block;
    width: 0.85rem;
    height: 2px;
    margin-top: 0.25rem;
    background: var(--color-pixel-mark);
    content: "";
    opacity: 0.7;
  }

  .home-menu__description {
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 38rem) {
    .home-menu a {
      grid-template-columns: 1.5rem 1fr auto;
      gap: 0.65rem;
    }

    .home-menu__description {
      display: none;
    }
  }
</style>
