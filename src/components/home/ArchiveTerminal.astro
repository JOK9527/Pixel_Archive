---
import HomeMenu from "./HomeMenu.astro";
import StatusPill from "../ui/StatusPill.astro";

type MenuItem = {
  label: string;
  href: string;
  description?: string;
};

type Props = {
  title: string;
  statusText?: string;
  menuItems: MenuItem[];
};

const {
  title,
  statusText = "archive online",
  menuItems,
} = Astro.props;
---

<section class="archive-terminal" aria-labelledby="archive-terminal-title">
  <div class="archive-terminal__topbar">
    <div class="archive-terminal__controls" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <p>PA-00 / INDEX</p>
    <StatusPill label={statusText} tone="green" pulse />
  </div>

  <div class="archive-terminal__content">
    <div class="archive-terminal__index" aria-hidden="true">
      <span>00</span>
      <i></i>
      <span>08</span>
      <i></i>
      <span>16</span>
    </div>
    <div class="archive-terminal__intro">
      <p class="archive-terminal__prompt">&gt; load archive_index</p>
      <h1 id="archive-terminal-title">{title}</h1>
      <p class="archive-terminal__message">
        Projects, notes, save points and small experiments.
      </p>
      <p class="archive-terminal__ready">
        READY<span class="archive-terminal__cursor" aria-hidden="true"></span>
      </p>
    </div>

    <HomeMenu items={menuItems} />
  </div>
  <div class="archive-terminal__footer" aria-hidden="true">
    <span class="pixel-mark"></span>
    <span>MEMORY MAP / 24 × 16</span>
    <span>SECTOR A-00</span>
  </div>
</section>

<style>
  .archive-terminal {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(90deg, var(--color-surface-deep) 0 3rem, transparent 3rem),
      var(--color-surface-raised);
    box-shadow:
      var(--shadow-soft),
      var(--shadow-inset),
      var(--shadow-pixel-soft);
  }

  .archive-terminal::before,
  .archive-terminal::after {
    position: absolute;
    content: "";
    pointer-events: none;
  }

  .archive-terminal::before {
    top: 2.75rem;
    right: 0;
    width: 12rem;
    height: var(--pixel-unit);
    background:
      repeating-linear-gradient(
        90deg,
        var(--color-border-strong) 0 12px,
        transparent 12px 20px,
        var(--color-pixel-mark) 20px 24px,
        transparent 24px 32px
      );
    opacity: 0.65;
  }

  .archive-terminal::after {
    right: 1.25rem;
    bottom: 3.2rem;
    width: calc(var(--pixel-unit) * 4);
    height: calc(var(--pixel-unit) * 4);
    background: var(--color-stone);
    box-shadow:
      calc(var(--pixel-unit) * -1) 0 0 var(--color-stone),
      0 calc(var(--pixel-unit) * -1) 0 var(--color-stone),
      calc(var(--pixel-unit) * -2) calc(var(--pixel-unit) * -2) 0
        var(--color-pixel-mark),
      calc(var(--pixel-unit) * -1) calc(var(--pixel-unit) * -2) 0
        var(--color-pixel-mark);
    opacity: 0.75;
  }

  .archive-terminal__topbar {
    display: grid;
    min-height: 2.75rem;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-inline: 1rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-deep);
  }

  .archive-terminal__topbar p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
  }

  .archive-terminal__topbar :global(.status-pill) {
    justify-self: end;
  }

  .archive-terminal__controls {
    display: flex;
    gap: 0.35rem;
  }

  .archive-terminal__controls span {
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-border);
  }

  .archive-terminal__controls span:nth-child(2) {
    background: var(--color-accent);
  }

  .archive-terminal__controls span:nth-child(3) {
    background: var(--color-green);
  }

  .archive-terminal__content {
    display: grid;
    grid-template-columns: 1.5rem minmax(17rem, 0.85fr) minmax(22rem, 1.15fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(1.5rem, 5vw, 4rem) clamp(1.5rem, 5vw, 4rem)
      clamp(2rem, 5vw, 3.5rem);
    background-image:
      linear-gradient(var(--color-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .archive-terminal__index {
    display: grid;
    grid-template-rows: auto 1fr auto 1fr auto;
    justify-items: center;
    color: var(--color-text-faint);
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.08em;
  }

  .archive-terminal__index i {
    width: 1px;
    height: 100%;
    background:
      repeating-linear-gradient(
        to bottom,
        var(--color-border-strong) 0 8px,
        transparent 8px 14px
      );
  }

  .archive-terminal__intro {
    align-self: center;
    padding-block: 1rem;
  }

  .archive-terminal__prompt,
  .archive-terminal__ready {
    margin-bottom: 1.15rem;
    color: var(--color-green);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .archive-terminal h1 {
    max-width: 8ch;
    margin-bottom: 1.25rem;
    font-size: clamp(3rem, 8vw, 6.85rem);
    letter-spacing: -0.075em;
    line-height: 0.82;
  }

  .archive-terminal__message {
    max-width: 29rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    font-size: clamp(0.95rem, 2vw, 1.08rem);
  }

  .archive-terminal__ready {
    display: flex;
    align-items: center;
    margin-bottom: 0;
    color: var(--color-accent);
  }

  .archive-terminal__footer {
    display: grid;
    min-height: 2.5rem;
    padding-inline: 1rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-deep);
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    color: var(--color-text-faint);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.09em;
  }

  .archive-terminal__footer > :last-child {
    justify-self: end;
  }

  .archive-terminal__cursor {
    width: 0.55rem;
    height: 1em;
    margin-inline-start: 0.45rem;
    background: currentColor;
    animation: cursor-blink 1.15s steps(1, end) infinite;
  }

  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 50rem) {
    .archive-terminal__content {
      grid-template-columns: 1.25rem 1fr;
    }

    .archive-terminal__intro,
    .archive-terminal :global(.home-menu) {
      grid-column: 2;
    }

    .archive-terminal__index {
      grid-row: 1 / 3;
    }

    .archive-terminal h1 {
      max-width: none;
    }
  }

  @media (max-width: 32rem) {
    .archive-terminal__topbar {
      grid-template-columns: 1fr auto;
    }

    .archive-terminal__topbar > p {
      display: none;
    }

    .archive-terminal__content {
      min-width: 0;
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }

    .archive-terminal__index {
      display: none;
    }

    .archive-terminal__intro,
    .archive-terminal :global(.home-menu) {
      grid-column: 1;
    }

    .archive-terminal__footer {
      grid-template-columns: 1fr auto;
    }

    .archive-terminal__footer > :nth-child(2) {
      display: none;
    }
  }
</style>
