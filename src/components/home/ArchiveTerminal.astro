---
import HomeMenu from "./HomeMenu.astro";
import StatusPill from "../ui/StatusPill.astro";

type MenuItem = {
  label: string;
  href: string;
  description?: string;
};

type Props = {
  title: string;
  statusText?: string;
  menuItems: MenuItem[];
};

const {
  title,
  statusText = "archive online",
  menuItems,
} = Astro.props;
---

<section class="archive-terminal" aria-labelledby="archive-terminal-title">
  <div class="archive-terminal__topbar">
    <div class="archive-terminal__controls" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <p>PA-00 / INDEX</p>
    <StatusPill label={statusText} tone="green" pulse />
  </div>

  <div class="archive-terminal__content">
    <div class="archive-terminal__intro">
      <p class="archive-terminal__prompt">&gt; load archive_index</p>
      <h1 id="archive-terminal-title">{title}</h1>
      <p class="archive-terminal__message">
        Projects, notes, save points and small experiments.
      </p>
      <p class="archive-terminal__ready">
        READY<span class="archive-terminal__cursor" aria-hidden="true"></span>
      </p>
    </div>

    <HomeMenu items={menuItems} />
  </div>
</section>

<style>
  .archive-terminal {
    position: relative;
    overflow: hidden;
    border: 2px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    box-shadow: var(--shadow-pixel);
  }

  .archive-terminal::after {
    position: absolute;
    right: -3rem;
    bottom: -3rem;
    width: 10rem;
    height: 10rem;
    border: 1px solid var(--color-purple-soft);
    content: "";
    opacity: 0.7;
    transform: rotate(45deg);
    pointer-events: none;
  }

  .archive-terminal__topbar {
    display: grid;
    min-height: 2.75rem;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-inline: 1rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-muted);
  }

  .archive-terminal__topbar p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
  }

  .archive-terminal__topbar :global(.status-pill) {
    justify-self: end;
  }

  .archive-terminal__controls {
    display: flex;
    gap: 0.35rem;
  }

  .archive-terminal__controls span {
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-border);
  }

  .archive-terminal__controls span:nth-child(2) {
    background: var(--color-purple);
  }

  .archive-terminal__controls span:nth-child(3) {
    background: var(--color-green);
  }

  .archive-terminal__content {
    display: grid;
    grid-template-columns: minmax(17rem, 0.85fr) minmax(22rem, 1.15fr);
    gap: clamp(2rem, 5vw, 5rem);
    padding: clamp(1.5rem, 5vw, 4rem);
  }

  .archive-terminal__intro {
    align-self: center;
  }

  .archive-terminal__prompt,
  .archive-terminal__ready {
    margin-bottom: 1.15rem;
    color: var(--color-green);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .archive-terminal h1 {
    max-width: 8ch;
    margin-bottom: 1.25rem;
    font-size: clamp(3rem, 8vw, 6.7rem);
    letter-spacing: -0.075em;
    line-height: 0.82;
  }

  .archive-terminal__message {
    max-width: 29rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    font-size: clamp(0.95rem, 2vw, 1.08rem);
  }

  .archive-terminal__ready {
    display: flex;
    align-items: center;
    margin-bottom: 0;
    color: var(--color-purple);
  }

  .archive-terminal__cursor {
    width: 0.55rem;
    height: 1em;
    margin-inline-start: 0.45rem;
    background: currentColor;
    animation: cursor-blink 1.15s steps(1, end) infinite;
  }

  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 50rem) {
    .archive-terminal__content {
      grid-template-columns: 1fr;
    }

    .archive-terminal h1 {
      max-width: none;
    }
  }

  @media (max-width: 32rem) {
    .archive-terminal__topbar {
      grid-template-columns: 1fr auto;
    }

    .archive-terminal__topbar > p {
      display: none;
    }

    .archive-terminal__content {
      min-width: 0;
      padding: 1.25rem;
    }
  }
</style>
