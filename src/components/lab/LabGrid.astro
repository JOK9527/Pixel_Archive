---
import type { LabItem } from "../../lib/content/lab";
import { toTaxonomyValue } from "../../lib/content/taxonomy";
import LabCard from "./LabCard.astro";

type Props = {
  items: LabItem[];
  filterRoot?: string;
};

const { items, filterRoot } = Astro.props;
---

<div class="lab-grid">
  {
    items.map((item) => (
      <div
        class="lab-grid__item"
        data-filter-root={filterRoot}
        data-type={toTaxonomyValue(item.type)}
        data-status={toTaxonomyValue(item.status)}
      >
        <LabCard
          title={item.title}
          description={item.description}
          type={item.type}
          tags={item.tags}
          status={item.status}
          href={item.href}
          cover={item.cover}
          coverMeta={item.coverMeta}
          date={item.date}
          seed={item.slug}
        />
      </div>
    ))
  }
</div>

<style>
  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
    gap: var(--space-5);
  }

  .lab-grid__item {
    min-width: 0;
  }

  .lab-grid__item > :global(*) {
    height: 100%;
  }
</style>
