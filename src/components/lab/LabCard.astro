---
import type { LabStatusValue, LabTypeValue } from "../../lib/content/lab";
import { getLabCoverVariant } from "../../lib/visual/pixel-cover";
import PixelCover from "../ui/PixelCover.astro";
import LabTypeBadge from "./LabTypeBadge.astro";

type Props = {
  title: string;
  description: string;
  type: LabTypeValue;
  tags?: string[];
  status?: LabStatusValue;
  href?: string;
  cover?: string;
  date?: string;
  seed?: string;
};

const {
  title,
  description,
  type,
  tags = [],
  status = "idea",
  href,
  cover,
  date,
  seed = title,
} = Astro.props;

const Element = href ? "a" : "article";
---

<Element
  class:list={["lab-card", "pixel-corner", `lab-card--${status}`]}
  href={href}
  aria-label={href ? `Open experiment: ${title}` : undefined}
>
  <div class="lab-card__screen">
    {
      cover ? (
        <img src={cover} alt="" loading="lazy" />
      ) : (
        <PixelCover
          variant={getLabCoverVariant(type)}
          section="lab"
          status={status}
          tags={tags}
          seed={seed}
          compact
          label={`${title} abstract experiment cover`}
        />
      )
    }
  </div>
  <div class="lab-card__meta">
    <LabTypeBadge type={type} />
    <span>{status}</span>
  </div>
  <h2>{title}</h2>
  <p>{description}</p>
  {
    (tags.length > 0 || date || href) && (
      <div class="lab-card__footer">
        {
          tags.length > 0 && (
            <ul aria-label="Lab tags">
              {tags.map((tag) => <li>#{tag}</li>)}
            </ul>
          )
        }
        {date && <time datetime={date}>{date}</time>}
        {href && <span class="lab-card__action">OPEN EXPERIMENT →</span>}
      </div>
    )
  }
</Element>

<style>
  .lab-card {
    display: flex;
    min-width: 0;
    padding: var(--space-5);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
    color: var(--color-text);
    flex-direction: column;
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .lab-card:hover,
  .lab-card:focus-visible {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md), var(--shadow-pixel-violet);
    color: var(--color-text);
    transform: translate(-2px, -2px);
  }

  .lab-card--prototype {
    box-shadow:
      inset 0 3px 0 var(--color-warning),
      var(--shadow-soft);
  }

  .lab-card--done {
    box-shadow:
      inset 0 3px 0 var(--color-status),
      var(--shadow-soft);
  }

  .lab-card__screen {
    min-height: 9rem;
    margin-bottom: var(--space-5);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-muted);
    background-image:
      linear-gradient(var(--color-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .lab-card__screen img {
    width: 100%;
    height: 100%;
    min-height: 9rem;
    object-fit: cover;
  }

  .lab-card__screen > :global(.pixel-cover) {
    min-height: 9rem;
  }

  .lab-card__meta {
    display: flex;
    margin-bottom: var(--space-3);
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .lab-card__meta > span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lab-card h2 {
    margin-bottom: var(--space-2);
    font-size: 1.3rem;
    letter-spacing: -0.035em;
  }

  .lab-card p {
    max-width: 32rem;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .lab-card__footer {
    display: grid;
    margin-top: auto;
    padding-top: var(--space-4);
    gap: var(--space-3);
  }

  .lab-card ul {
    display: flex;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-violet);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    list-style: none;
  }

  .lab-card time {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
  }

  .lab-card__action {
    display: inline-block;
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
