---
import type { LabTypeValue } from "../../lib/content/lab";

type Props = {
  type: LabTypeValue;
};

const { type } = Astro.props;
---

<span class="lab-type ui-label">{type}</span>

<style>
  .lab-type {
    display: inline-flex;
    padding: 0.28rem 0.48rem;
    border: 1px solid color-mix(in srgb, var(--color-violet) 32%, var(--color-border));
    background: var(--color-violet-soft);
    color: var(--color-violet);
    font-family: var(--font-ui);
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: var(--tracking-ui);
    line-height: 1;
    text-transform: uppercase;
  }
</style>
