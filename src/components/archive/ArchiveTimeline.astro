---
import type { ArchiveYearGroup } from "../../lib/content/archive";
import ArchiveEntry from "./ArchiveEntry.astro";

type Props = {
  groups: ArchiveYearGroup[];
};

const { groups } = Astro.props;

const monthLabels = [
  "JAN",
  "FEB",
  "MAR",
  "APR",
  "MAY",
  "JUN",
  "JUL",
  "AUG",
  "SEP",
  "OCT",
  "NOV",
  "DEC",
];
---

<div class="archive-timeline">
  {
    groups.map((group) => (
      <section class="archive-year" aria-labelledby={`archive-year-${group.year}`}>
        <h2 id={`archive-year-${group.year}`}>{group.year}</h2>
        <div class="archive-year__months">
          {group.months.map((month) => (
            <section
              class="archive-month"
              aria-labelledby={`archive-month-${group.year}-${month.month}`}
            >
              <h3 id={`archive-month-${group.year}-${month.month}`}>
                {monthLabels[Number(month.month) - 1] ?? month.month}
              </h3>
              <div class="archive-month__entries">
                {month.entries.map((entry) => (
                  <ArchiveEntry
                    title={entry.title}
                    date={entry.date}
                    type={entry.type}
                    description={entry.description}
                    relatedHref={entry.relatedHref}
                  />
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    ))
  }
</div>

<style>
  .archive-timeline {
    max-width: 52rem;
  }

  .archive-year {
    display: grid;
    grid-template-columns: 6rem minmax(0, 1fr);
    gap: 2rem;
  }

  .archive-year > h2 {
    position: sticky;
    top: 1rem;
    height: fit-content;
    margin-bottom: 0;
    color: var(--color-purple);
    font-family: var(--font-mono);
    font-size: 1.1rem;
  }

  .archive-year__months {
    display: grid;
    gap: 2.5rem;
  }

  .archive-month {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr);
    gap: 1.25rem;
  }

  .archive-month > h3 {
    margin-bottom: 0;
    color: var(--color-green);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .archive-month__entries {
    position: relative;
    display: grid;
    padding-left: 1.7rem;
    gap: 1rem;
  }

  .archive-month__entries::before {
    position: absolute;
    top: 0.3rem;
    bottom: 0.3rem;
    left: 0;
    width: 1px;
    background: var(--color-border-strong);
    content: "";
  }

  @media (max-width: 40rem) {
    .archive-year {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .archive-year > h2 {
      position: static;
    }

    .archive-month {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }
</style>
