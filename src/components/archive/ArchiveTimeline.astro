---
import type { ArchiveYearGroup } from "../../lib/content/archive";
import { getYearMonth, toTaxonomyValue } from "../../lib/content/taxonomy";
import ArchiveEntry from "./ArchiveEntry.astro";

type Props = {
  groups: ArchiveYearGroup[];
  filterRoot?: string;
};

const { groups, filterRoot } = Astro.props;

const monthLabels = [
  "JAN",
  "FEB",
  "MAR",
  "APR",
  "MAY",
  "JUN",
  "JUL",
  "AUG",
  "SEP",
  "OCT",
  "NOV",
  "DEC",
];
---

<div class="archive-timeline">
  {
    groups.map((group) => (
      <section
        class="archive-year"
        aria-labelledby={`archive-year-${group.year}`}
        data-filter-section={filterRoot}
      >
        <h2 id={`archive-year-${group.year}`}>{group.year}</h2>
        <div class="archive-year__months">
          {group.months.map((month) => (
            <section
              class="archive-month"
              aria-labelledby={`archive-month-${group.year}-${month.month}`}
              data-filter-section={filterRoot}
            >
              <h3 id={`archive-month-${group.year}-${month.month}`}>
                {monthLabels[Number(month.month) - 1] ?? month.month}
              </h3>
              <div class="archive-month__entries coordinate-grid">
                {month.entries.map((entry) => (
                  <div
                    class="archive-month__record"
                    data-filter-root={filterRoot}
                    data-type={toTaxonomyValue(entry.type)}
                    data-year={toTaxonomyValue(getYearMonth(entry.date))}
                  >
                    <ArchiveEntry
                      slug={entry.slug}
                      title={entry.title}
                      date={entry.date}
                      type={entry.type}
                      description={entry.description}
                      coverMeta={entry.coverMeta}
                      relatedHref={entry.relatedHref}
                    />
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    ))
  }
</div>

<style>
  .archive-timeline {
    max-width: var(--measure-wide);
  }

  .archive-year {
    display: grid;
    grid-template-columns: 6rem minmax(0, 1fr);
    gap: var(--space-6);
  }

  .archive-year > h2 {
    position: sticky;
    top: var(--space-5);
    height: fit-content;
    margin-bottom: 0;
    color: var(--color-warm-strong);
    font-family: var(--font-mono);
    font-size: 1.1rem;
  }

  .archive-year__months {
    display: grid;
    gap: var(--space-7);
  }

  .archive-month {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr);
    gap: var(--space-5);
  }

  .archive-month > h3 {
    margin-bottom: 0;
    padding-top: var(--space-1);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .archive-month__entries {
    --timeline-offset: var(--space-6);

    position: relative;
    display: grid;
    padding-left: var(--timeline-offset);
    background-color: color-mix(
      in srgb,
      var(--color-surface) 94%,
      transparent
    );
    gap: var(--space-5);
  }

  .archive-month__entries::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: var(--pixel-unit);
    background:
      repeating-linear-gradient(
        to bottom,
        var(--color-border-strong) 0 calc(var(--pixel-unit) * 3),
        transparent calc(var(--pixel-unit) * 3) calc(var(--pixel-unit) * 5)
      );
    content: "";
  }

  .archive-month__record {
    min-width: 0;
  }

  @media (max-width: 40rem) {
    .archive-year {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .archive-year > h2 {
      position: static;
    }

    .archive-month {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .archive-month__entries {
      --timeline-offset: var(--space-5);
    }
  }
</style>
