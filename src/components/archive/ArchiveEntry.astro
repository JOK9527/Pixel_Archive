---
import type { ArchiveTypeValue } from "../../lib/content/archive";

type Props = {
  title: string;
  date: string;
  type: ArchiveTypeValue;
  description?: string;
  relatedHref?: string;
};

const { title, date, type, description, relatedHref } = Astro.props;

const typeLabels = {
  "save-point": "SAVE POINT",
  milestone: "MILESTONE",
  "project-log": "PROJECT LOG",
} as const;
---

<article class:list={["archive-entry", `archive-entry--${type}`]}>
  <span class="archive-entry__node" aria-hidden="true"></span>
  <div class="archive-entry__header">
    <time datetime={date}>{date}</time>
    <span>{typeLabels[type]}</span>
  </div>
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  {
    relatedHref && (
      <a href={relatedHref}>
        open related file <span aria-hidden="true">→</span>
      </a>
    )
  }
</article>

<style>
  .archive-entry {
    position: relative;
    padding: 1.25rem 1.25rem 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .archive-entry__node {
    position: absolute;
    top: 1.3rem;
    left: -2.05rem;
    width: 0.7rem;
    height: 0.7rem;
    border: 2px solid var(--color-bg);
    background: var(--color-accent);
    box-shadow:
      0 0 0 2px var(--color-border),
      4px 4px 0 color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .archive-entry--milestone .archive-entry__node {
    background: var(--color-green);
  }

  .archive-entry--project-log .archive-entry__node {
    background: var(--color-warning);
  }

  .archive-entry__header {
    display: flex;
    margin-bottom: 0.65rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.07em;
  }

  .archive-entry h3 {
    margin-bottom: 0.45rem;
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }

  .archive-entry p {
    margin-bottom: 0.85rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .archive-entry a {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 32rem) {
    .archive-entry__header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
