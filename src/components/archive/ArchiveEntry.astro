---
import type { ArchiveTypeValue } from "../../lib/content/archive";
import type { CoverMeta } from "../../lib/visual/pixel-cover-system";
import ArchiveSavePoint from "./ArchiveSavePoint.astro";

type Props = {
  slug: string;
  title: string;
  date: string;
  type: ArchiveTypeValue;
  description?: string;
  coverMeta?: CoverMeta;
  relatedHref?: string;
};

const { slug, title, date, type, description, coverMeta, relatedHref } =
  Astro.props;

---

<article
  id={slug}
  class:list={["archive-entry", "pixel-corner", `archive-entry--${type}`]}
>
  <span class="archive-entry__node" aria-hidden="true"></span>
  <ArchiveSavePoint
    date={date}
    title={title}
    type={type}
    seed={slug}
    coverMeta={coverMeta}
  />
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  {
    relatedHref && (
      <a class="ui-label" href={relatedHref}>
        OPEN RELATED FILE <span aria-hidden="true">→</span>
      </a>
    )
  }
</article>

<style>
  .archive-entry {
    position: relative;
    scroll-margin-top: 2rem;
    padding: var(--space-5);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
  }

  .archive-entry__node {
    position: absolute;
    /* Absolute positioning starts at the padding box; offset the 1px card border. */
    top: -1px;
    left: calc(
      (var(--timeline-offset, var(--space-6)) * -1) +
        (var(--pixel-unit) / 2) - 1px
    );
    width: 0.7rem;
    height: 0.7rem;
    border: 2px solid var(--color-bg);
    background: var(--color-warm);
    box-shadow:
      0 0 0 2px var(--color-border),
      4px 4px 0 color-mix(in srgb, var(--color-warm) 30%, transparent);
    transform: translate(-50%, -50%);
  }

  .archive-entry--milestone .archive-entry__node {
    background: var(--color-green);
  }

  .archive-entry--project-log .archive-entry__node {
    background: var(--color-accent);
  }

  .archive-entry h3 {
    margin-bottom: var(--space-2);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
    color: var(--color-heading);
  }

  .archive-entry p {
    max-width: 34rem;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .archive-entry a {
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
  }

</style>
