---
import { site } from "../../data/site";

type Props = {
  quote?: string;
};

const { quote = site.footerText } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="ui-label">{site.name} / {currentYear}</p>
    <p class="site-footer__status ui-label"><span aria-hidden="true"></span>{quote}</p>
    <nav class="ui-label" aria-label="Publishing links">
      <a href="/topics/">Topics</a>
      <a href="/rss.xml">RSS</a>
      <span>Built with {site.builtWith}</span>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-ui);
    font-size: 0.75rem;
  }

  .site-footer__inner {
    display: flex;
    width: min(100% - 2rem, var(--content-width));
    min-height: 4.25rem;
    margin-inline: auto;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-footer p {
    margin: 0;
  }

  .site-footer nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-footer nav a {
    color: var(--color-text-muted);
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 0.2em;
  }

  .site-footer nav a:hover {
    color: var(--color-link-hover);
  }

  .site-footer__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .site-footer__status span {
    width: 0.45rem;
    height: 0.45rem;
    background: var(--color-status);
    box-shadow: 3px 3px 0 var(--color-status-soft);
  }

  @media (max-width: 42rem) {
    .site-footer__inner {
      width: min(100% - 1.25rem, var(--content-width));
      padding-block: 1.25rem;
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .site-footer nav {
      align-items: flex-start;
      flex-wrap: wrap;
    }
  }
</style>
