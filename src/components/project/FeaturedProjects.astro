---
import type { ProjectItem } from "../../lib/content/projects";
import ProjectGrid from "./ProjectGrid.astro";

type Props = {
  projects: ProjectItem[];
  filterRoot?: string;
};

const { projects, filterRoot } = Astro.props;
---

{
  projects.length > 0 && (
    <section
      class="featured-projects"
      aria-labelledby="featured-projects-title"
      data-filter-section={filterRoot}
    >
      <header>
        <h2 id="featured-projects-title">Featured Projects</h2>
      </header>
      <ProjectGrid projects={projects} featured filterRoot={filterRoot} />
    </section>
  )
}

<style>
  .featured-projects {
    margin-bottom: clamp(3.5rem, 8vw, 6rem);
  }

  .featured-projects header {
    margin-bottom: 1.4rem;
  }

  .featured-projects h2 {
    margin-bottom: 0;
    font-size: clamp(1.8rem, 5vw, 2.7rem);
    letter-spacing: -0.05em;
  }
</style>
