---
import type {
  ProjectLinksValue,
  ProjectStatusValue,
  ProjectTypeValue,
} from "../../lib/content/projects";
import { getProjectCoverVariant } from "../../lib/visual/pixel-cover";
import PixelCover from "../ui/PixelCover.astro";
import ProjectStatus from "./ProjectStatus.astro";
import ProjectTechStack from "./ProjectTechStack.astro";

type Props = {
  title: string;
  slug: string;
  description: string;
  projectType: ProjectTypeValue;
  status: ProjectStatusValue;
  category: string;
  tags?: string[];
  techStack?: string[];
  href: string;
  cover?: string;
  links?: ProjectLinksValue;
  featured?: boolean;
};

const {
  title,
  slug,
  description,
  projectType,
  status,
  category,
  tags = [],
  techStack = [],
  href,
  cover,
  featured = false,
} = Astro.props;
---

<article
  class:list={[
    "project-card",
    "pixel-corner",
    { "project-card--featured": featured },
  ]}
>
  <a class="project-card__link" href={href} aria-label={`Open project: ${title}`}>
    <div class="project-card__cover">
      {
        cover ? (
          <img src={cover} alt="" loading="lazy" />
        ) : (
          <PixelCover
            variant={getProjectCoverVariant(projectType)}
            section="projects"
            status={status}
            tags={techStack}
            seed={slug}
            compact={!featured}
            label={`${title} abstract project cover`}
          />
        )
      }
    </div>

    <div class="project-card__body">
      <div class="project-card__meta">
        <span>{category}</span>
        <ProjectStatus status={status} />
      </div>
      <h2>{title}</h2>
      <p>{description}</p>
      <ProjectTechStack items={techStack} compact />
      {
        tags.length > 0 && (
          <ul class="project-card__tags" aria-label="Project tags">
            {tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )
      }
      <span class="project-card__action">load project →</span>
    </div>
  </a>
</article>

<style>
  .project-card {
    overflow: visible;
    min-width: 0;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md), var(--shadow-pixel-green);
    transform: translate(-2px, -2px);
  }

  .project-card--featured {
    border-color: var(--color-border-strong);
    box-shadow:
      var(--shadow-pixel-green),
      var(--shadow-md);
  }

  .project-card__link {
    display: grid;
    height: 100%;
    overflow: hidden;
    color: var(--color-text);
    grid-template-rows: auto 1fr;
    text-decoration: none;
  }

  .project-card__cover {
    min-height: 12rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-muted);
  }

  .project-card__cover img {
    width: 100%;
    height: 100%;
    min-height: 12rem;
    object-fit: cover;
  }

  .project-card--featured .project-card__cover {
    min-height: 15rem;
  }

  .project-card__cover > :global(.pixel-cover) {
    height: 100%;
    min-height: 12rem;
  }

  .project-card--featured .project-card__cover > :global(.pixel-cover) {
    min-height: 15rem;
  }

  .project-card__body {
    display: flex;
    min-width: 0;
    padding: var(--space-5);
    flex-direction: column;
  }

  .project-card__meta {
    display: flex;
    margin-bottom: var(--space-3);
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .project-card__meta > span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .project-card h2 {
    margin-bottom: var(--space-2);
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--color-heading);
  }

  .project-card p {
    max-width: 34rem;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .project-card__tags {
    display: flex;
    margin: var(--space-4) 0 0;
    padding: 0;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--section-accent);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    list-style: none;
  }

  .project-card__action {
    margin-top: auto;
    padding-top: var(--space-5);
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
