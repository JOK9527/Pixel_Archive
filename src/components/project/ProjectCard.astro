---
import type {
  ProjectLinksValue,
  ProjectStatusValue,
} from "../../lib/content/projects";
import ProjectStatus from "./ProjectStatus.astro";
import ProjectTechStack from "./ProjectTechStack.astro";

type Props = {
  title: string;
  description: string;
  status: ProjectStatusValue;
  category: string;
  tags?: string[];
  techStack?: string[];
  href: string;
  cover?: string;
  links?: ProjectLinksValue;
  featured?: boolean;
};

const {
  title,
  description,
  status,
  category,
  tags = [],
  techStack = [],
  href,
  cover,
  featured = false,
} = Astro.props;
---

<article
  class:list={[
    "project-card",
    "pixel-corners",
    { "project-card--featured": featured },
  ]}
>
  <a class="project-card__link" href={href} aria-label={`Open project: ${title}`}>
    <div class="project-card__cover">
      {
        cover ? (
          <img src={cover} alt="" loading="lazy" />
        ) : (
          <div class="project-card__placeholder" aria-hidden="true">
            <div class="project-card__glyph">
              {Array.from({ length: 15 }, (_, index) => <span data-index={index}></span>)}
            </div>
            <span>PROJECT / NO COVER</span>
          </div>
        )
      }
    </div>

    <div class="project-card__body">
      <div class="project-card__meta">
        <span>{category}</span>
        <ProjectStatus status={status} />
      </div>
      <h2>{title}</h2>
      <p>{description}</p>
      <ProjectTechStack items={techStack} compact />
      {
        tags.length > 0 && (
          <ul class="project-card__tags" aria-label="Project tags">
            {tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )
      }
      <span class="project-card__action">load project →</span>
    </div>
  </a>
</article>

<style>
  .project-card {
    min-width: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-pixel);
    transform: translate(-1px, -1px);
  }

  .project-card--featured {
    border-color: var(--color-border-strong);
    box-shadow:
      inset 0 3px 0 var(--color-pixel-mark),
      var(--shadow-soft);
  }

  .project-card__link {
    display: grid;
    height: 100%;
    overflow: hidden;
    color: var(--color-text);
    grid-template-rows: auto 1fr;
    text-decoration: none;
  }

  .project-card__cover {
    min-height: 9rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-muted);
  }

  .project-card__cover img {
    width: 100%;
    height: 100%;
    min-height: 9rem;
    object-fit: cover;
  }

  .project-card__placeholder {
    display: flex;
    min-height: 9rem;
    padding: 1rem;
    background:
      linear-gradient(
        90deg,
        transparent 0 calc(100% - 1px),
        color-mix(in srgb, var(--color-border) 38%, transparent)
          calc(100% - 1px)
      ),
      linear-gradient(
        color-mix(in srgb, var(--color-border) 32%, transparent) 0 1px,
        transparent 1px 100%
      ),
      var(--color-surface-muted);
    background-size: 2rem 2rem;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .project-card__glyph {
    display: grid;
    width: 6.5rem;
    height: 4.5rem;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.3rem;
    align-items: end;
  }

  .project-card__glyph span {
    min-height: 0.45rem;
    background: var(--color-border-strong);
  }

  .project-card__glyph span:nth-child(4n + 1) {
    height: 100%;
    background: var(--color-pixel-mark);
  }

  .project-card__glyph span:nth-child(3n + 2) {
    height: 55%;
  }

  .project-card__glyph span:nth-child(5n) {
    height: 75%;
    background: var(--color-accent);
  }

  .project-card__body {
    display: flex;
    min-width: 0;
    padding: 1.25rem;
    flex-direction: column;
  }

  .project-card__meta {
    display: flex;
    margin-bottom: 1rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .project-card__meta > span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .project-card h2 {
    margin-bottom: 0.55rem;
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .project-card p {
    margin-bottom: 1.2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .project-card__tags {
    display: flex;
    margin: 1rem 0 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 0.55rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    list-style: none;
  }

  .project-card__action {
    margin-top: auto;
    padding-top: 1.3rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
