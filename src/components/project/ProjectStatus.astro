---
import type { ProjectStatusValue } from "../../lib/content/projects";

type Props = {
  status: ProjectStatusValue;
};

const { status } = Astro.props;

const statusMeta = {
  WIP: { label: "WIP", tone: "purple" },
  Done: { label: "Done", tone: "green" },
  Prototype: { label: "Prototype", tone: "warning" },
  Paused: { label: "Paused", tone: "muted" },
} as const;

const meta = statusMeta[status];
---

<span
  class:list={[
    "project-status",
    "status-block",
    "ui-label",
    `project-status--${meta.tone}`,
  ]}
>
  <span class="project-status__signal" aria-hidden="true">
    <i></i><i></i><i></i>
  </span>
  {meta.label}
</span>

<style>
  .project-status {
    display: inline-flex;
    width: fit-content;
    min-height: 1.75rem;
    padding: 0.3rem 0.55rem 0.3rem 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: var(--tracking-ui);
    line-height: 1;
    text-transform: uppercase;
    background: var(--color-surface);
  }

  .project-status::before {
    display: none;
  }

  .project-status__signal {
    display: grid;
    width: calc(var(--pixel-unit) * 3);
    height: calc(var(--pixel-unit) * 3);
    grid-template-columns: repeat(3, var(--pixel-unit));
    grid-template-rows: repeat(3, var(--pixel-unit));
  }

  .project-status__signal i {
    width: var(--pixel-unit);
    height: var(--pixel-unit);
    align-self: end;
    background: currentColor;
  }

  .project-status__signal i:nth-child(1) {
    grid-row: 3;
  }

  .project-status__signal i:nth-child(2) {
    grid-row: 2 / 4;
    height: calc(var(--pixel-unit) * 2);
  }

  .project-status__signal i:nth-child(3) {
    grid-row: 1 / 4;
    height: calc(var(--pixel-unit) * 3);
  }

  .project-status--purple {
    border-color: color-mix(in srgb, var(--color-warning) 45%, var(--color-border));
    background: var(--color-warning-soft);
    color: var(--color-warning);
  }

  .project-status--green {
    color: var(--color-green);
  }

  .project-status--warning {
    color: var(--color-warning);
  }

  .project-status--muted {
    color: var(--color-text-muted);
  }
</style>
