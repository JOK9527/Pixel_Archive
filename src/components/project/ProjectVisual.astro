---
import type { ProjectItem } from "../../lib/content/projects";
import { normalizeCoverMeta } from "../../lib/visual/pixel-cover-system";
import PixelCover from "../cover/PixelCover.astro";

type Props = {
  project: ProjectItem;
};

const { project } = Astro.props;
const coverRecipe = normalizeCoverMeta({
  kind: "project",
  title: project.title,
  seed: project.slug,
  status: project.status,
  tagCount: project.techStack.length,
  coverMeta: {
    ...project.coverMeta,
    density: project.coverMeta?.density ?? "high",
  },
});
---

<figure class="project-visual">
  {
    project.cover ? (
      <img src={project.cover} alt="" loading="eager" />
    ) : (
      <PixelCover
        kind="project"
        variant={coverRecipe.variant}
        code={coverRecipe.code}
        title={project.title}
        subtitle={project.description}
        meta={project.techStack}
        tags={project.tags}
        status={project.status}
        progress={coverRecipe.progress}
        date={project.updatedDate ?? project.startDate}
        seed={coverRecipe.seed}
        accent={coverRecipe.accent}
        density={coverRecipe.density}
        showHeat={coverRecipe.showHeat}
        label="PROJECT CODE"
      />
    )
  }
  <figcaption>
    Abstract system record. Product screenshots remain withheld until content and
    identity details pass the public-release review.
  </figcaption>
</figure>

<style>
  .project-visual {
    margin: 0 0 clamp(3rem, 7vw, 5rem);
  }

  .project-visual > img,
  .project-visual > :global(.pixel-cover),
  .project-visual > :global(.pixel-cover-system) {
    min-height: clamp(15rem, 34vw, 23rem);
    border: 1px solid var(--color-border-strong);
    box-shadow: var(--shadow-pixel-green), var(--shadow-md);
  }

  .project-visual > img {
    width: 100%;
    object-fit: cover;
  }

  .project-visual figcaption {
    margin-top: 0.75rem;
    color: var(--color-text-faint);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    line-height: 1.6;
  }
</style>
