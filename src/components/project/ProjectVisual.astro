---
import type { ProjectItem } from "../../lib/content/projects";
import { getProjectCoverRecipe } from "../../lib/visual/pixel-cover";
import PixelCover from "../ui/PixelCover.astro";

type Props = {
  project: ProjectItem;
};

const { project } = Astro.props;
const coverRecipe = getProjectCoverRecipe(project.type, true);
---

<figure class="project-visual">
  {
    project.cover ? (
      <img src={project.cover} alt="" loading="eager" />
    ) : (
      <PixelCover
        variant={coverRecipe.variant}
        section="projects"
        status={project.status}
        tags={project.techStack}
        seed={project.slug}
        accent={coverRecipe.accent}
        density={coverRecipe.density}
        label={`${project.title} abstract system record`}
      />
    )
  }
  <figcaption>
    Abstract system record. Product screenshots remain withheld until content and
    identity details pass the public-release review.
  </figcaption>
</figure>

<style>
  .project-visual {
    margin: 0 0 clamp(3rem, 7vw, 5rem);
  }

  .project-visual > img,
  .project-visual > :global(.pixel-cover) {
    min-height: clamp(15rem, 34vw, 23rem);
    border: 1px solid var(--color-border-strong);
    box-shadow: var(--shadow-pixel-green), var(--shadow-md);
  }

  .project-visual > img {
    width: 100%;
    object-fit: cover;
  }

  .project-visual figcaption {
    margin-top: 0.75rem;
    color: var(--color-text-faint);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    line-height: 1.6;
  }
</style>
