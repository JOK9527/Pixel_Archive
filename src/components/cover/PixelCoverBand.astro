---
type Props = {
  label: string;
  value?: string;
  progress?: number;
  orientation?: "horizontal" | "vertical";
  compact?: boolean;
};

const {
  label,
  value,
  progress,
  orientation = "horizontal",
  compact = false,
} = Astro.props;
const normalizedProgress =
  progress === undefined ? undefined : Math.min(100, Math.max(0, progress));
---

<div
  class:list={[
    "pixel-cover-band",
    `pixel-cover-band--${orientation}`,
    { "pixel-cover-band--compact": compact },
  ]}
  style={normalizedProgress === undefined ? undefined : `--band-progress:${normalizedProgress}%`}
>
  <span>{label}</span>
  {value && <strong>{value}</strong>}
  {normalizedProgress !== undefined && <i aria-hidden="true"></i>}
</div>

<style>
  .pixel-cover-band {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 2.2rem;
    padding: 0.6rem 0.75rem;
    overflow: hidden;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--color-border);
    background: var(
      --cover-band-surface,
      color-mix(
        in srgb,
        var(--cover-accent) 12%,
        var(--color-surface-raised)
      )
    );
    color: var(--cover-band-ink, var(--color-heading));
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .pixel-cover-band > :is(span, strong) {
    position: relative;
    z-index: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pixel-cover-band strong {
    color: var(--cover-band-accent, var(--cover-accent));
  }

  .pixel-cover-band i {
    position: absolute;
    bottom: 0;
    left: 0;
    width: var(--band-progress);
    height: var(--pixel-unit);
    background: var(--cover-band-accent, var(--cover-accent));
  }

  .pixel-cover-band--vertical {
    min-width: 2.4rem;
    min-height: 100%;
    padding: 0.75rem 0.45rem;
    border-top: 0;
    border-right: 1px solid var(--color-border);
    flex-direction: column;
    justify-content: flex-start;
    writing-mode: vertical-rl;
  }

  .pixel-cover-band--vertical i {
    top: 0;
    bottom: auto;
    width: var(--pixel-unit);
    height: var(--band-progress);
  }

  .pixel-cover-band--compact {
    min-height: 1.85rem;
    padding: 0.45rem 0.6rem;
    font-size: 0.54rem;
  }
</style>
